---
// editor.astro — client editing UI (chat right / live preview left).
// /api/edit-site saves a Blob draft and returns rendered HTML (shown via
// iframe srcdoc). Revert undoes the last edit; Publish commits to main;
// History (branded popup) uses list-versions + restore-version.
import brand from '../../site-config/brand.json';

const LIVE_URL = 'https://red-hill-0fb2bdf10.7.azurestaticapps.net';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<script is:inline>if(!localStorage.getItem('2labs_sites_token'))location.replace('/login');</script>
<title>{brand.orgName} — Site Editor</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<!-- is:global so JS-created elements (messages, chips, history rows) are styled too. -->
<style is:global>
  :root{
    --amber:#F59F0A; --amber-dark:#D9870A; --amber-tint:rgba(245,159,10,0.08); --amber-tint-strong:#FFFBEB;
    --ink:#1F242E; --ink-soft:#676F7E; --bg:#F8F7F6; --surface:#FFFFFF; --border:#E5E0DC;
    --green:#2F8558; --green-bg:#EAF6EF; --red:#C0392B; --red-bg:#FBEAE8;
    --radius:14px; --shadow:0 1px 2px rgba(31,36,46,0.04), 0 10px 28px rgba(31,36,46,0.06);
  }
  *{box-sizing:border-box;}
  html,body{ height:100%; }
  body{
    margin:0; background:var(--bg); color:var(--ink);
    font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased;
    display:flex; flex-direction:column; height:100vh; overflow:hidden;
  }
  h1,h2,h3,.display{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.01em; }
  .dog{ width:100%; height:100%; display:block; }

  .topbar{ display:flex; align-items:center; justify-content:space-between; padding:12px 20px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
  .topbar-left{ display:flex; align-items:center; gap:14px; }
  .back-btn{ width:32px;height:32px;border-radius:50%; border:1px solid var(--border); background:var(--surface); display:flex;align-items:center;justify-content:center; color:var(--ink-soft); cursor:pointer; font-size:15px; flex-shrink:0; text-decoration:none; }
  .back-btn:hover{ color:var(--ink); border-color:var(--ink-soft); }
  .brand-mark{ width:30px;height:30px;border-radius:50%; overflow:hidden; flex-shrink:0; }
  .brand-mark img{ width:100%;height:100%; object-fit:cover; display:block; }
  .site-meta{ line-height:1.25; }
  .site-name{ font-weight:700; font-size:14.5px; }
  .site-status{ display:flex; align-items:center; gap:6px; font-size:11.5px; color:var(--ink-soft); }
  .status-dot{ width:6px;height:6px;border-radius:50%; background:var(--amber); }
  .status-dot.clean{ background:var(--green); }

  .topbar-right{ display:flex; align-items:center; gap:10px; }
  .btn{ border:none; border-radius:9px; padding:9px 16px; font-family:'Inter',sans-serif; font-weight:600; font-size:13px; cursor:pointer; display:inline-flex; align-items:center; gap:6px; text-decoration:none; }
  .btn-ghost{ background:var(--bg); color:var(--ink); border:1px solid var(--border); }
  .btn-ghost:hover:not(:disabled){ border-color:var(--ink-soft); }
  .btn-primary{ background:var(--amber); color:var(--ink); }
  .btn-primary:hover:not(:disabled){ background:var(--amber-dark); }
  .btn:disabled{ opacity:0.45; cursor:not-allowed; }
  .btn .spin{ width:13px;height:13px;border-radius:50%; border:2px solid rgba(31,36,46,0.3); border-top-color:var(--ink); animation:spin .8s linear infinite; }

  .main{ flex:1; display:flex; min-height:0; }

  .preview-col{ flex:1; display:flex; flex-direction:column; min-width:0; background:var(--bg); padding:18px 20px; }
  .preview-toolbar{ display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .preview-pages{ display:flex; gap:6px; background:var(--surface); border:1px solid var(--border); border-radius:9px; padding:3px; }
  .preview-pages button{ border:none; background:transparent; padding:6px 12px; border-radius:7px; font-size:12.5px; font-weight:600; color:var(--ink-soft); cursor:pointer; }
  .preview-pages button.active{ background:var(--ink); color:#fff; }
  .preview-pages button:disabled{ opacity:.5; cursor:not-allowed; }
  .preview-label{ font-size:12.5px; font-weight:600; color:var(--ink-soft); }
  .preview-left{ display:flex; align-items:center; gap:10px; }
  .page-select{ font-family:'Inter',sans-serif; font-size:12.5px; font-weight:600; color:var(--ink); background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:6px 26px 6px 10px; cursor:pointer; appearance:none; background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' fill='none' stroke='%23676F7E' stroke-width='1.5' stroke-linecap='round'/></svg>"); background-repeat:no-repeat; background-position:right 9px center; }
  .page-select:hover{ border-color:var(--ink-soft); }
  .page-select:focus{ outline:none; border-color:var(--amber); }
  .preview-controls{ display:flex; align-items:center; gap:10px; }
  .refresh-btn{ width:32px;height:32px;border-radius:8px;border:1px solid var(--border); background:var(--surface); color:var(--ink-soft); cursor:pointer; font-size:14px; display:flex;align-items:center;justify-content:center; }
  .refresh-btn:hover{ color:var(--ink); }
  .viewport-toggle{ display:flex; gap:6px; }
  .viewport-toggle button{ width:32px;height:32px; border-radius:8px; border:1px solid var(--border); background:var(--surface); color:var(--ink-soft); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:14px; }
  .viewport-toggle button.active{ background:var(--ink); color:var(--amber); border-color:var(--ink); }

  .preview-stage{ flex:1; display:flex; align-items:stretch; justify-content:center; overflow:hidden; padding-bottom:10px; }
  .preview-frame{ position:relative; width:100%; max-width:100%; display:flex; flex-direction:column; background:#fff; border-radius:12px; overflow:hidden; box-shadow:var(--shadow); border:1px solid var(--border); transition:max-width .25s ease; }
  .preview-frame.tablet{ max-width:768px; }
  .preview-frame.mobile{ max-width:390px; }
  .preview-chrome{ background:#EFEDEA; padding:8px 12px; display:flex; align-items:center; gap:6px; flex-shrink:0; }
  .preview-chrome span{ width:8px;height:8px;border-radius:50%; background:#D6D1CA; }
  .preview-url{ margin-left:6px; background:#fff; border-radius:6px; padding:3px 10px; font-size:10.5px; color:var(--ink-soft); flex:1; }
  .preview-iframe{ flex:1; width:100%; border:none; background:#fff; transition:opacity .3s ease, filter .3s ease; }
  /* Working state: fade the preview + show an overlay while the AI works. */
  .preview-frame.working .preview-iframe{ opacity:0.35; filter:blur(2px); pointer-events:none; }
  .preview-working{ position:absolute; inset:0; z-index:5; display:none; flex-direction:column; align-items:center; justify-content:center; gap:14px; background:rgba(248,247,246,0.35); backdrop-filter:blur(1px); }
  .preview-frame.working .preview-working{ display:flex; }
  .preview-working .ring{ width:46px;height:46px;border-radius:50%; border:3px solid rgba(31,36,46,0.14); border-top-color:var(--amber); animation:spin .8s linear infinite; }
  .preview-working .label{ display:flex; align-items:center; gap:8px; font-size:13px; font-weight:600; color:var(--ink); background:var(--surface); border:1px solid var(--border); padding:8px 15px; border-radius:100px; box-shadow:var(--shadow); }
  .preview-working .label .pulse{ width:7px;height:7px;border-radius:50%; background:var(--amber); animation:pulse 1.1s ease-in-out infinite; }
  @keyframes pulse{ 0%,100%{ opacity:0.35; transform:scale(0.85); } 50%{ opacity:1; transform:scale(1.15); } }
  .preview-notconnected{ position:absolute; inset:0; z-index:6; display:none; align-items:center; justify-content:center; background:var(--bg); }
  .nc-card{ text-align:center; max-width:340px; padding:0 24px; }
  .nc-title{ font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:18px; }
  .nc-sub{ font-size:13.5px; color:var(--ink-soft); margin:8px 0 18px; line-height:1.5; }
  .nc-btn{ display:inline-block; background:var(--amber); color:var(--ink); font-weight:600; font-size:14px; padding:11px 20px; border-radius:10px; text-decoration:none; }
  .nc-btn:hover{ background:var(--amber-dark); }
  .credits{ display:flex; align-items:center; gap:8px; padding:0 12px 0 4px; margin-right:4px; border-right:1px solid var(--border); }
  .credits-bar{ width:60px; height:6px; border-radius:100px; background:#EDE8E4; overflow:hidden; }
  .credits-fill{ display:block; height:100%; width:0%; border-radius:100px; background:var(--green, #2F8558); transition:width .4s ease, background .3s; }
  .credits-fill.warn{ background:var(--amber, #F59F0A); } .credits-fill.full{ background:#C0392B; }
  .credits-label{ font-size:12px; font-weight:600; color:var(--ink-soft); white-space:nowrap; }

  /* ---- Branded chat ---- */
  .chat-col{ width:390px; flex-shrink:0; display:flex; flex-direction:column; background:var(--surface); border-left:1px solid var(--border); min-height:0; }
  .chat-head{ padding:15px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:11px; background:linear-gradient(180deg, var(--amber-tint-strong), var(--surface)); }
  .chat-head .badge{ width:34px;height:34px;border-radius:50%; background:#F6EDE1; display:flex;align-items:center;justify-content:center; flex-shrink:0; padding:6px; }
  .chat-head h3{ font-size:14.5px; margin:0; }
  .chat-head p{ font-size:12px; color:var(--ink-soft); margin:2px 0 0; }

  .chat-body{ flex:1; overflow-y:auto; padding:16px 18px; display:flex; flex-direction:column; gap:14px; }
  .msg{ max-width:90%; display:flex; gap:8px; }
  .msg.user{ align-self:flex-end; flex-direction:row-reverse; }
  .msg.assistant{ align-self:flex-start; }
  .msg .avatar{ width:24px;height:24px;border-radius:50%; background:#F6EDE1; flex-shrink:0; display:flex;align-items:center;justify-content:center; padding:4px; margin-top:2px; }
  .msg.user .avatar{ background:var(--ink); color:#fff; font-size:11px; font-weight:700; padding:0; }
  .msg .col{ display:flex; flex-direction:column; min-width:0; }
  .bubble{ padding:10px 13px; border-radius:14px; font-size:13.5px; line-height:1.5; white-space:pre-wrap; word-wrap:break-word; }
  .msg.user .bubble{ background:var(--ink); color:#fff; border-top-right-radius:5px; }
  .msg.assistant .bubble{ background:var(--bg); border:1px solid var(--border); border-top-left-radius:5px; }
  .msg.assistant .bubble.error{ background:var(--red-bg); border-color:#EBC9C4; color:var(--red); }
  .msg-time{ font-size:10.5px; color:var(--ink-soft); margin-top:4px; }
  .msg.user .msg-time{ text-align:right; }

  .diff-chip{ display:flex; align-items:center; gap:8px; margin-top:9px; padding:8px 10px; border-radius:9px; background:var(--green-bg); border:1px solid #CFE9D8; font-size:12px; }
  .diff-chip .dot{ width:6px;height:6px;border-radius:50%; background:var(--green); flex-shrink:0; }
  .diff-chip b{ font-weight:600; }
  .building{ display:flex; align-items:center; gap:8px; font-size:12px; color:var(--ink-soft); }
  .building .spinner{ width:12px;height:12px;border-radius:50%; border:2px solid var(--border); border-top-color:var(--amber); animation:spin 0.8s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg); } }

  .suggestion-row{ display:flex; gap:8px; flex-wrap:wrap; padding:0 18px 12px; }
  .suggestion-chip{ border:1px solid var(--border); background:var(--surface); border-radius:100px; padding:6px 12px; font-size:11.5px; font-weight:600; color:var(--ink-soft); cursor:pointer; white-space:nowrap; }
  .suggestion-chip:hover{ border-color:var(--amber); color:var(--amber-dark); }

  .chat-input{ border-top:1px solid var(--border); padding:12px 14px; display:flex; flex-direction:column; gap:8px; flex-shrink:0; }
  .attach-tray{ display:flex; flex-wrap:wrap; gap:8px; }
  .attach-tray:empty{ display:none; }
  .attach-chip{ display:flex; align-items:center; gap:8px; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:6px 8px; font-size:12px; max-width:200px; }
  .attach-chip img{ width:28px; height:28px; object-fit:cover; border-radius:6px; flex-shrink:0; }
  .attach-chip .ic{ width:28px; height:28px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
  .attach-chip .nm{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .attach-chip .rm{ margin-left:2px; cursor:pointer; color:var(--ink-soft); border:none; background:none; font-size:15px; line-height:1; padding:0 2px; }
  .attach-chip .rm:hover{ color:var(--ink); }
  .attach-chip.uploading{ opacity:.55; }
  .chat-input-row{ display:flex; align-items:flex-end; gap:8px; }
  .chat-input textarea{ flex:1; resize:none; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-family:'Inter',sans-serif; font-size:13.5px; line-height:1.5; color:var(--ink); background:var(--bg); min-height:120px; max-height:320px; }
  .chat-input textarea:focus{ outline:none; border-color:var(--amber); }
  .chat-input textarea:disabled{ opacity:.6; }
  .attach-btn{ width:38px; height:38px; border-radius:10px; border:1px solid var(--border); background:var(--bg); color:var(--ink-soft); cursor:pointer; font-size:16px; flex-shrink:0; }
  .attach-btn:hover{ border-color:var(--amber); color:var(--ink); }
  .attach-btn:disabled{ opacity:.5; cursor:not-allowed; }
  .msg.user .bubble .att{ display:flex; align-items:center; gap:6px; margin-top:6px; font-size:12px; opacity:.85; }
  .msg.user .bubble .att img{ width:22px; height:22px; object-fit:cover; border-radius:5px; }
  .send-btn{ width:38px;height:38px;border-radius:10px; border:none; background:var(--ink); color:var(--amber); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
  .send-btn:disabled{ opacity:.5; cursor:not-allowed; }

  /* ---- History popup (branded modal) ---- */
  .modal-overlay{ position:fixed; inset:0; background:rgba(31,36,46,0.45); display:none; z-index:60; align-items:center; justify-content:center; padding:24px; }
  .modal-overlay.open{ display:flex; }
  .modal{ width:100%; max-width:520px; max-height:80vh; background:var(--surface); border-radius:18px; box-shadow:0 24px 60px rgba(15,23,42,0.28); display:flex; flex-direction:column; overflow:hidden; }
  .modal-head{ display:flex; align-items:center; gap:11px; padding:18px 20px; border-bottom:1px solid var(--border); background:linear-gradient(180deg, var(--amber-tint-strong), var(--surface)); }
  .modal-head .badge{ width:32px;height:32px;border-radius:50%; background:#F6EDE1; display:flex;align-items:center;justify-content:center; padding:6px; flex-shrink:0; }
  .modal-head h3{ font-size:16px; margin:0; flex:1; }
  .modal-head p{ font-size:11.5px; color:var(--ink-soft); margin:2px 0 0; }
  .modal-close{ border:none; background:var(--bg); border:1px solid var(--border); width:30px;height:30px;border-radius:8px; color:var(--ink-soft); cursor:pointer; font-size:14px; }
  .modal-close:hover{ color:var(--ink); }
  .modal-body{ flex:1; overflow-y:auto; }
  .modal-empty{ padding:28px 20px; font-size:13px; color:var(--ink-soft); text-align:center; }
  .version-item{ padding:14px 20px; border-bottom:1px solid var(--border); display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
  .version-item:last-child{ border-bottom:none; }
  .version-msg{ font-size:13.5px; font-weight:500; }
  .version-meta{ font-size:11.5px; color:var(--ink-soft); margin-top:3px; }
  .version-load{ border:1px solid var(--amber); color:var(--amber-dark); background:#fff; font-size:12px; font-weight:600; padding:6px 12px; border-radius:8px; cursor:pointer; white-space:nowrap; flex-shrink:0; }
  .version-load:hover:not(:disabled){ background:var(--amber); color:var(--ink); }
  .version-load:disabled{ opacity:.5; cursor:not-allowed; }
</style>
</head>
<body>

  <div class="topbar">
    <div class="topbar-left">
      <a class="back-btn" href="/dashboard" title="Back to dashboard" aria-label="Back to dashboard">←</a>
      <div class="brand-mark"><img src="/logo.png" alt="2Labs" width="30" height="30" /></div>
      <div class="site-meta">
        <div class="site-name">{brand.domain}</div>
        <div class="site-status"><span class="status-dot" id="statusDot"></span> <span id="statusText">Draft</span></div>
      </div>
    </div>
    <div class="topbar-right">
      <div class="credits" id="credits" title="AI edits used this month">
        <div class="credits-bar"><span class="credits-fill" id="creditsFill"></span></div>
        <span class="credits-label" id="creditsLabel">— / —</span>
      </div>
      <button class="btn btn-ghost" id="revertBtn" disabled title="Undo the last change">↶ Revert</button>
      <button class="btn btn-ghost" id="historyBtn">History</button>
      <a class="btn btn-ghost" href={LIVE_URL} target="_blank" rel="noopener">View Live ↗</a>
      <button class="btn btn-primary" id="publishBtn" title="Publish your draft changes to the live site.">Publish Changes</button>
      <button class="btn btn-ghost" id="signOut" title="Sign out">Sign out</button>
    </div>
  </div>

  <div class="main">
    <div class="preview-col">
      <div class="preview-toolbar">
        <div class="preview-left">
          <div class="preview-label" id="previewLabel">Live preview</div>
          <select class="page-select" id="pageSelect" title="Jump to a page" aria-label="Preview a page">
            <option value="">All pages…</option>
          </select>
        </div>
        <div class="preview-controls">
          <button class="refresh-btn" id="refreshBtn" title="Refresh preview">⟳</button>
          <div class="viewport-toggle">
            <button class="active" data-vp="desktop" title="Desktop">🖥</button>
            <button data-vp="tablet" title="Tablet">▤</button>
            <button data-vp="mobile" title="Mobile">📱</button>
          </div>
        </div>
      </div>
      <div class="preview-stage">
        <div class="preview-frame" id="previewFrame">
          <div class="preview-chrome"><span></span><span></span><span></span><div class="preview-url" id="previewUrl">{brand.domain} — live</div></div>
          <iframe class="preview-iframe" id="previewIframe" title="Site preview"></iframe>
          <div class="preview-working"><div class="ring"></div><div class="label"><span class="pulse"></span> <span id="previewWorkingLabel">2Labs AI is working…</span></div></div>
          <div class="preview-notconnected" id="notConnected" style="display:none">
            <div class="nc-card">
              <div class="nc-title">This site isn't connected yet</div>
              <div class="nc-sub">Add its GitHub repository to start building and editing here.</div>
              <a class="nc-btn" id="ncSettings" href="#">Open settings →</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="chat-col">
      <div class="chat-head">
        <div class="badge"><svg class="dog" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 46 C12 38 13 30 17 24 C19 21 22 19 25 19 C27 19 28 20.5 28 22.5 C28 25 26.5 26 25.5 28 C24 31 24 35 25 39 C26 43 27 46 27 46 Z" stroke="#1F242E" stroke-width="2.5" stroke-linejoin="round"/><path d="M31 46 C29 37 30 28 35 22 C37.5 19 41 17 44 17 C46.5 17 48 18.7 48 21 C48 24 46 25.5 44.5 28 C42.5 31.5 42.5 36 43.5 40.5 C44.5 44 46 46 46 46 Z" fill="#F59F0A"/></svg></div>
        <div>
          <h3>2Labs Studio AI</h3>
          <p>Edit or add pages — describe it, or paste content to build from.</p>
        </div>
      </div>

      <div class="chat-body" id="chatBody"></div>

      <div class="suggestion-row" id="suggestionRow">
        <div class="suggestion-chip">Add a Services page</div>
        <div class="suggestion-chip">Add an About page with our story</div>
        <div class="suggestion-chip">Add an interactive FAQ accordion</div>
      </div>

      <div class="chat-input">
        <div class="attach-tray" id="attachTray"></div>
        <div class="chat-input-row">
          <button class="attach-btn" id="attachBtn" title="Attach a photo or PDF to use as content">📎</button>
          <textarea id="promptInput" placeholder="Describe a change, paste content, or attach a photo/PDF — e.g. &quot;Use this image on the homepage&quot;"></textarea>
          <button class="send-btn" id="sendBtn" title="Send">↑</button>
        </div>
        <input type="file" id="fileInput" accept="image/*,application/pdf" multiple hidden />
      </div>
    </div>
  </div>

  <!-- History popup -->
  <div class="modal-overlay" id="historyOverlay">
    <div class="modal">
      <div class="modal-head">
        <div class="badge"><svg class="dog" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 46 C12 38 13 30 17 24 C19 21 22 19 25 19 C27 19 28 20.5 28 22.5 C28 25 26.5 26 25.5 28 C24 31 24 35 25 39 C26 43 27 46 27 46 Z" stroke="#1F242E" stroke-width="2.5" stroke-linejoin="round"/><path d="M31 46 C29 37 30 28 35 22 C37.5 19 41 17 44 17 C46.5 17 48 18.7 48 21 C48 24 46 25.5 44.5 28 C42.5 31.5 42.5 36 43.5 40.5 C44.5 44 46 46 46 46 Z" fill="#F59F0A"/></svg></div>
        <div style="flex:1"><h3>Version history</h3><p>Published versions of {brand.domain}</p></div>
        <button class="modal-close" id="historyClose" aria-label="Close">✕</button>
      </div>
      <div class="modal-body" id="historyBody"><div class="modal-empty">Loading…</div></div>
    </div>
  </div>

  <script define:vars={{ LIVE_URL, orgName: brand.orgName }}>
    const TOKEN_KEY = '2labs_sites_token';
    const SITE = new URLSearchParams(location.search).get('site');
    if (!SITE) location.replace('/dashboard'); // the editor is opened for a specific site
    const authToken = () => localStorage.getItem(TOKEN_KEY);
    const signOut = () => { localStorage.removeItem(TOKEN_KEY); location.replace('/login'); };
    const DOG = '<svg class="dog" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 46 C12 38 13 30 17 24 C19 21 22 19 25 19 C27 19 28 20.5 28 22.5 C28 25 26.5 26 25.5 28 C24 31 24 35 25 39 C26 43 27 46 27 46 Z" stroke="#1F242E" stroke-width="3" stroke-linejoin="round"/><path d="M31 46 C29 37 30 28 35 22 C37.5 19 41 17 44 17 C46.5 17 48 18.7 48 21 C48 24 46 25.5 44.5 28 C42.5 31.5 42.5 36 43.5 40.5 C44.5 44 46 46 46 46 Z" fill="#F59F0A"/></svg>';

    document.getElementById('signOut').addEventListener('click', signOut);

    const chatBody = document.getElementById('chatBody');
    const input = document.getElementById('promptInput');
    const sendBtn = document.getElementById('sendBtn');
    const iframe = document.getElementById('previewIframe');
    const previewFrame = document.getElementById('previewFrame');
    const previewUrl = document.getElementById('previewUrl');
    const statusDot = document.getElementById('statusDot');
    const statusText = document.getElementById('statusText');
    const revertBtn = document.getElementById('revertBtn');
    let busy = false, lastHtml = null;

    const timeNow = () => new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
    const scrollDown = () => { chatBody.scrollTop = chatBody.scrollHeight; };

    function apiFetch(path, opts = {}) {
      return fetch(path, { ...opts, headers: { 'Content-Type': 'application/json', 'x-2labs-session': authToken() || '', 'Authorization': 'Bearer ' + (authToken() || ''), ...(opts.headers || {}) } });
    }

    function addUser(text) {
      const el = document.createElement('div'); el.className = 'msg user';
      const av = document.createElement('div'); av.className = 'avatar'; av.textContent = 'You';
      const col = document.createElement('div'); col.className = 'col';
      const b = document.createElement('div'); b.className = 'bubble'; b.textContent = text;
      for (const a of arguments[1] || []) {
        const r = document.createElement('div'); r.className = 'att';
        if (a.type && a.type.startsWith('image/')) { const im = document.createElement('img'); im.src = a.url; r.appendChild(im); }
        else { const ic = document.createElement('span'); ic.textContent = '📄'; r.appendChild(ic); }
        const nm = document.createElement('span'); nm.textContent = a.name; r.appendChild(nm);
        b.appendChild(r);
      }
      const t = document.createElement('div'); t.className = 'msg-time'; t.textContent = timeNow();
      col.append(b, t); el.append(av, col); chatBody.appendChild(el); scrollDown();
    }
    function addAssistant(text, { error = false, time = timeNow() } = {}) {
      const el = document.createElement('div'); el.className = 'msg assistant';
      const av = document.createElement('div'); av.className = 'avatar'; av.innerHTML = DOG;
      const col = document.createElement('div'); col.className = 'col';
      const b = document.createElement('div'); b.className = 'bubble' + (error ? ' error' : ''); b.textContent = text;
      col.appendChild(b);
      if (time) { const t = document.createElement('div'); t.className = 'msg-time'; t.textContent = time; col.appendChild(t); }
      el.append(av, col); chatBody.appendChild(el); scrollDown();
      return { el, bubble: b };
    }

    addAssistant(`Hi 👋 I'm your 2Labs studio AI. I can edit ${orgName}'s site or add new pages — I'll write the content, wire it into the navigation, and follow SEO/UX best practices. Describe what you want (paste in any copy or notes to build from), and I'll show it in the preview. When it looks right, hit Publish Changes.`, { time: '' });

    // Injected into every previewed page so internal nav links render the
    // target DRAFT page in-place (instead of navigating the iframe to the SWA
    // origin, which 404s for unpublished pages). External links open in a tab.
    const NAV_SCRIPT = '<scr' + 'ipt>(function(){document.addEventListener("click",function(e){var a=e.target.closest&&e.target.closest("a");if(!a)return;var href=a.getAttribute("href");if(!href||href[0]==="#"||/^(mailto:|tel:)/i.test(href))return;e.preventDefault();if(/^https?:\\/\\//i.test(href)||a.target==="_blank"){window.open(href,"_blank");return;}parent.postMessage({__2labs:true,type:"navigate",href:href},"*");},true);document.addEventListener("submit",function(e){e.preventDefault();},true);})();</scr' + 'ipt>';
    function injectNav(html) { return html.includes('</body>') ? html.replace('</body>', NAV_SCRIPT + '</body>') : html + NAV_SCRIPT; }
    function renderIntoPreview(html) { lastHtml = html; iframe.removeAttribute('src'); iframe.srcdoc = injectNav(html); }

    function setPreviewHtml(html) {
      renderIntoPreview(html);
      previewUrl.textContent = document.querySelector('.site-name').textContent + ' — draft (unpublished)';
      statusDot.classList.remove('clean'); statusText.textContent = 'Unpublished changes';
    }
    function refreshPreview() { if (lastHtml != null) renderIntoPreview(lastHtml); else iframe.src = LIVE_URL + '/?t=' + Date.now(); }

    // Render a draft page by URL path when a nav link is clicked in the preview.
    async function navigatePreview(href) {
      setPreviewWorking(true);
      try {
        const res = await apiFetch('/api/preview-page', { method: 'POST', body: JSON.stringify({ path: href }) });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { setTimeout(signOut, 200); return; }
        if (data.status === 'ok' && typeof data.html === 'string') { renderIntoPreview(data.html); setPreviewLabel(data.file); }
        else if (data.status === 'not_found') { addAssistant(data.message || `That page doesn't exist yet — ask me to create it.`); }
        else { addAssistant(data.detail ? `Preview failed — ${data.detail}` : 'Could not open that page.', { error: true }); }
      } catch (err) { addAssistant('Could not open that page in the preview.', { error: true }); }
      finally { setPreviewWorking(false); }
    }
    window.addEventListener('message', (e) => {
      const d = e.data;
      if (d && d.__2labs === true && d.type === 'navigate') navigatePreview(d.href);
    });
    function setBusy(state) { busy = state; sendBtn.disabled = state; input.disabled = state; const ab = document.getElementById('attachBtn'); if (ab) ab.disabled = state || uploading > 0; }
    function setCanRevert(v) { revertBtn.disabled = !v; }
    function setPreviewWorking(v, label) {
      if (v && label) { const el = document.getElementById('previewWorkingLabel'); if (el) el.textContent = label; }
      previewFrame.classList.toggle('working', v);
    }
    function setStatus(hasDrafts) {
      const name = document.querySelector('.site-name').textContent;
      if (hasDrafts) { statusDot.classList.remove('clean'); statusText.textContent = 'Unpublished changes'; previewUrl.textContent = name + ' — draft (unpublished)'; }
      else { statusDot.classList.add('clean'); statusText.textContent = 'Up to date'; previewUrl.textContent = name + ' — current site'; }
    }

    // On load, show the current DRAFT state (draft-or-disk), not the live site —
    // so returning to unfinished edits shows them, not the published version.
    async function loadInitialPreview() {
      setPreviewWorking(true, 'Loading your site…');
      try {
        const res = await apiFetch('/api/preview-page', { method: 'POST', body: JSON.stringify({ path: '/' }) });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { setTimeout(signOut, 200); return; }
        if (data.status === 'ok' && typeof data.html === 'string') {
          renderIntoPreview(data.html); setPreviewLabel(data.file); setStatus(!!data.hasDrafts);
        } else {
          iframe.src = LIVE_URL; // fallback if the draft render is unavailable
        }
      } catch (err) { iframe.src = LIVE_URL; }
      finally { setPreviewWorking(false); }
    }
    function fileToRoute(file) {
      let p = String(file || '').replace('src/pages/', '').replace('.astro', '');
      if (p === 'index') return '/';
      if (p.endsWith('/index')) p = p.slice(0, -6);
      return '/' + p;
    }
    function setPreviewLabel(primaryPath) {
      const el = document.getElementById('previewLabel');
      if (!primaryPath) { el.textContent = 'Live preview'; return; }
      const base = primaryPath.replace('src/pages/', '').replace('.astro', '');
      el.textContent = 'Previewing: ' + (base === 'index' ? 'Home' : base.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()));
      // Keep the page selector in sync with what's shown.
      const route = fileToRoute(primaryPath);
      if ([...pageSelect.options].some((o) => o.value === route)) pageSelect.value = route;
    }

    // ---- Page selector (jump the preview to any page) ----
    const pageSelect = document.getElementById('pageSelect');
    async function loadPages(selectRoute) {
      try {
        const res = await apiFetch('/api/list-pages');
        if (!res.ok) return;
        const data = await res.json();
        const pages = (data.pages || []);
        if (!pages.length) return;
        const current = selectRoute || pageSelect.value || '/';
        pageSelect.innerHTML = pages.map((p) => `<option value="${p.route}">${p.label}</option>`).join('');
        if ([...pageSelect.options].some((o) => o.value === current)) pageSelect.value = current;
      } catch (e) { /* selector stays as-is */ }
    }
    pageSelect.addEventListener('change', () => { if (pageSelect.value) navigatePreview(pageSelect.value); });

    async function submit(prompt, atts = []) {
      addUser(prompt, atts);
      setBusy(true);
      setPreviewWorking(true);
      const thinking = addAssistant('', { time: '' });
      thinking.bubble.innerHTML = '<span class="building"><span class="spinner"></span> Thinking…</span>';
      try {
        const attachments = atts.map((a) => ({ id: a.id, url: a.url, name: a.name, type: a.type }));
        const res = await apiFetch('/api/edit-site', { method: 'POST', body: JSON.stringify({ prompt, attachments }) });
        const data = await res.json().catch(() => ({}));
        thinking.el.remove();
        if (res.status === 401) { addAssistant('Your session has expired. Redirecting you to sign in…', { error: true }); setTimeout(signOut, 1200); return; }
        if (!res.ok) { const m = data.detail ? `${data.error || 'Error'} — ${data.detail}` : (data.error || `Something went wrong (HTTP ${res.status}).`); addAssistant(m, { error: true }); return; }
        if (data.status === 'no_change') { addAssistant('That didn’t change anything — the content already matches. Try describing it differently.'); return; }
        if (data.status === 'ok' && typeof data.html === 'string') {
          setPreviewHtml(data.html);
          setPreviewLabel(data.primary);
          setCanRevert(true);
          refreshCredits();
          loadPages(fileToRoute(data.primary)); // a new page may have been created
          const m = addAssistant(data.summary || 'Done — updated your site. The preview is live on the left.');
          const files = Array.isArray(data.files) ? data.files : [];
          const nice = files.map((f) => f.replace('src/pages/', '').replace('src/components/', '').replace('.astro', '')).join(', ');
          const chip = document.createElement('div'); chip.className = 'diff-chip';
          const dot = document.createElement('span'); dot.className = 'dot';
          const txt = document.createElement('span');
          txt.innerHTML = files.length ? `<b>Updated:</b> ${nice}. Publish when it looks right, or Revert to undo.` : '<b>Draft updated.</b> Publish when it looks right, or Revert to undo.';
          chip.append(dot, txt); m.bubble.appendChild(chip); scrollDown(); return;
        }
        addAssistant('Unexpected response from the server.', { error: true });
      } catch (err) { thinking.el.remove(); addAssistant('Could not reach the editor service. Check your connection and try again.', { error: true }); }
      finally { setBusy(false); setPreviewWorking(false); }
    }
    function send() {
      const text = input.value.trim();
      if ((!text && pendingAttachments.length === 0) || busy || uploading > 0) return;
      const atts = pendingAttachments.slice();
      input.value = ''; pendingAttachments = []; renderTray();
      submit(text, atts);
    }
    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });

    // ---- Attachments (photo / PDF the AI uses as content) ----
    let pendingAttachments = [];
    let uploading = 0;
    const attachTray = document.getElementById('attachTray');
    const attachBtn = document.getElementById('attachBtn');
    const fileInput = document.getElementById('fileInput');

    function renderTray() {
      attachTray.innerHTML = '';
      for (const a of pendingAttachments) {
        const chip = document.createElement('div'); chip.className = 'attach-chip' + (a.uploading ? ' uploading' : '');
        if (a.preview) { const im = document.createElement('img'); im.src = a.preview; chip.appendChild(im); }
        else { const ic = document.createElement('span'); ic.className = 'ic'; ic.textContent = a.type === 'application/pdf' ? '📄' : '🖼️'; chip.appendChild(ic); }
        const nm = document.createElement('span'); nm.className = 'nm'; nm.textContent = a.uploading ? 'Uploading…' : a.name; chip.appendChild(nm);
        if (!a.uploading) { const rm = document.createElement('button'); rm.className = 'rm'; rm.textContent = '×'; rm.title = 'Remove'; rm.onclick = () => { pendingAttachments = pendingAttachments.filter((x) => x !== a); renderTray(); }; chip.appendChild(rm); }
        attachTray.appendChild(chip);
      }
    }

    const readAsBase64 = (file) => new Promise((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(String(r.result).split(',')[1] || '');
      r.onerror = () => reject(new Error('read failed'));
      r.readAsDataURL(file);
    });

    async function uploadFile(file) {
      const okType = file.type.startsWith('image/') || file.type === 'application/pdf';
      if (!okType) { addAssistant(`“${file.name}” isn’t a supported type. Attach a photo (PNG/JPG/WebP/GIF/SVG) or a PDF.`, { error: true }); return; }
      if (file.size > 8 * 1024 * 1024) { addAssistant(`“${file.name}” is larger than 8 MB. Please attach a smaller file.`, { error: true }); return; }
      const placeholder = { uploading: true, name: file.name, type: file.type, preview: file.type.startsWith('image/') ? URL.createObjectURL(file) : null };
      pendingAttachments.push(placeholder); uploading++; renderTray(); attachBtn.disabled = true;
      try {
        const dataBase64 = await readAsBase64(file);
        const res = await apiFetch('/api/upload-asset', { method: 'POST', body: JSON.stringify({ name: file.name, type: file.type, dataBase64 }) });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { signOut(); return; }
        const i = pendingAttachments.indexOf(placeholder);
        if (data.status === 'ok' && data.asset) {
          const a = Object.assign({}, data.asset, { uploading: false, preview: placeholder.preview });
          if (i !== -1) pendingAttachments[i] = a; else pendingAttachments.push(a);
        } else {
          if (i !== -1) pendingAttachments.splice(i, 1);
          addAssistant(data.error || `Could not upload “${file.name}”.`, { error: true });
        }
      } catch (e) {
        const i = pendingAttachments.indexOf(placeholder); if (i !== -1) pendingAttachments.splice(i, 1);
        addAssistant(`Could not upload “${file.name}”. Try again.`, { error: true });
      } finally {
        uploading--; if (uploading <= 0) attachBtn.disabled = false; renderTray();
      }
    }

    attachBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => {
      for (const f of Array.from(fileInput.files || [])) uploadFile(f);
      fileInput.value = '';
    });
    document.getElementById('suggestionRow').addEventListener('click', (e) => { const c = e.target.closest('.suggestion-chip'); if (c) { input.value = c.textContent.trim(); input.focus(); } });

    document.querySelectorAll('.viewport-toggle button').forEach((btn) => btn.addEventListener('click', () => {
      document.querySelectorAll('.viewport-toggle button').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active'); previewFrame.classList.remove('tablet', 'mobile');
      if (btn.dataset.vp !== 'desktop') previewFrame.classList.add(btn.dataset.vp);
    }));
    document.getElementById('refreshBtn').addEventListener('click', () => loadInitialPreview());

    // AI credit meter (1 edit = 1 credit). Refreshed on load and after edits.
    async function refreshCredits() {
      try {
        const res = await apiFetch('/api/usage');
        if (!res.ok) return;
        const u = await res.json();
        const limit = u.limit || 0, used = u.used || 0;
        const pct = limit ? Math.min(100, Math.round((used / limit) * 100)) : 0;
        const fill = document.getElementById('creditsFill');
        fill.style.width = pct + '%';
        fill.classList.toggle('warn', pct >= 80 && pct < 100);
        fill.classList.toggle('full', pct >= 100);
        document.getElementById('creditsLabel').textContent = `${used} / ${limit} edits`;
        const reset = u.resetsOn ? new Date(u.resetsOn).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) : '';
        document.getElementById('credits').title = `${u.remaining} AI edits left this month${reset ? ' · resets ' + reset : ''}`;
        if (pct >= 100) addAssistant(`You’ve used all ${limit} AI edits for this month. Your allowance resets ${reset}.`);
        else if (used === limit - 1) addAssistant(`Heads up — this is your last AI edit for the month (resets ${reset}).`);
      } catch (e) { /* meter is best-effort */ }
    }

    // Resolve the selected site, then show its current draft state.
    async function initSite() {
      try {
        const res = await apiFetch('/api/list-sites');
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { signOut(); return; }
        const site = (data.sites || []).find((s) => s.slug === SITE);
        if (!site) { location.replace('/dashboard'); return; }
        document.querySelector('.site-name').textContent = site.name;
        refreshCredits();
        if (!site.editable) { showNotConnected(site); return; }
        loadPages();
        loadInitialPreview();
      } catch (e) { loadInitialPreview(); }
    }
    function showNotConnected(site) {
      setPreviewWorking(false);
      previewFrame.classList.add('not-connected');
      document.getElementById('notConnected').style.display = 'flex';
      document.getElementById('ncSettings').href = '/site-settings?site=' + encodeURIComponent(SITE);
      input.disabled = true; sendBtn.disabled = true;
      input.placeholder = 'Connect this site to start editing…';
      addAssistant(`${site.name} isn't connected yet. Set up its GitHub repo in Settings, and I'll be able to build and edit it here.`);
    }
    initSite();

    // ---- Revert last change ----
    revertBtn.addEventListener('click', async () => {
      if (busy || revertBtn.disabled) return;
      const label = revertBtn.innerHTML;
      revertBtn.disabled = true; revertBtn.innerHTML = '<span class="spin"></span> Reverting…';
      setPreviewWorking(true);
      try {
        const res = await apiFetch('/api/revert-draft', { method: 'POST', body: '{}' });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { setTimeout(signOut, 200); return; }
        if (!res.ok) { addAssistant(data.detail ? `Revert failed — ${data.detail}` : (data.error || 'Revert failed.'), { error: true }); revertBtn.innerHTML = label; setCanRevert(true); return; }
        if (data.status === 'nothing_to_revert') { addAssistant('There’s no change to revert.'); revertBtn.innerHTML = label; return; }
        if (typeof data.html === 'string') setPreviewHtml(data.html);
        addAssistant('Reverted the last change.', { time: timeNow() });
        revertBtn.innerHTML = label; setCanRevert(false); // one level of undo
      } catch (err) { addAssistant('Could not reach the revert service. Try again.', { error: true }); revertBtn.innerHTML = label; setCanRevert(true); }
      finally { setPreviewWorking(false); }
    });

    // ---- Publish ----
    const publishBtn = document.getElementById('publishBtn');
    publishBtn.addEventListener('click', async () => {
      if (busy) return;
      if (!confirm('Publish your draft changes to the live site? This updates production.')) return;
      const label = publishBtn.textContent;
      publishBtn.disabled = true; publishBtn.innerHTML = '<span class="spin"></span> Publishing…';
      try {
        const res = await apiFetch('/api/publish-site', { method: 'POST', body: JSON.stringify({ site: SITE }) });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { addAssistant('Your session has expired. Redirecting you to sign in…', { error: true }); setTimeout(signOut, 1200); return; }
        if (data.status === 'not_connected') { addAssistant((data.message || 'Connect this site’s GitHub repo in Settings before publishing.') + ' You can add it under Settings for this site.', { error: true }); return; }
        if (!res.ok) { addAssistant(data.error || data.detail || `Publish failed (HTTP ${res.status}).`, { error: true }); return; }
        if (data.status === 'nothing_to_publish') { addAssistant('There are no draft changes to publish yet.'); return; }
        addAssistant(`Published ${data.count} file(s) — production is rebuilding now. It’ll be live in a minute or two.`, { time: timeNow() });
        lastHtml = null; setCanRevert(false);
        statusDot.classList.add('clean'); statusText.textContent = 'Published';
      } catch (err) { addAssistant('Could not reach the publish service. Try again.', { error: true }); }
      finally { publishBtn.disabled = false; publishBtn.textContent = label; }
    });

    // ---- History popup ----
    const overlay = document.getElementById('historyOverlay');
    const historyBody = document.getElementById('historyBody');
    document.getElementById('historyBtn').addEventListener('click', openHistory);
    document.getElementById('historyClose').addEventListener('click', () => overlay.classList.remove('open'));
    overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });

    const fmtDate = (iso) => { try { return new Date(iso).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }); } catch { return iso || ''; } };

    async function openHistory() {
      overlay.classList.add('open');
      historyBody.innerHTML = '<div class="modal-empty">Loading…</div>';
      try {
        const res = await apiFetch('/api/list-versions', { method: 'GET' });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { overlay.classList.remove('open'); setTimeout(signOut, 200); return; }
        if (!res.ok || !Array.isArray(data.versions)) { historyBody.innerHTML = '<div class="modal-empty">Could not load history.</div>'; return; }
        if (data.versions.length === 0) { historyBody.innerHTML = '<div class="modal-empty">No published versions yet.</div>'; return; }
        historyBody.innerHTML = '';
        for (const v of data.versions) {
          const item = document.createElement('div'); item.className = 'version-item';
          const left = document.createElement('div');
          const msg = document.createElement('div'); msg.className = 'version-msg'; msg.textContent = v.message;
          const meta = document.createElement('div'); meta.className = 'version-meta'; meta.textContent = `${v.shortSha} · ${v.author || 'unknown'} · ${fmtDate(v.date)}`;
          left.append(msg, meta);
          const load = document.createElement('button'); load.className = 'version-load'; load.textContent = 'Load into editor';
          load.addEventListener('click', () => restoreVersion(v.sha, load));
          item.append(left, load);
          historyBody.appendChild(item);
        }
      } catch (err) { historyBody.innerHTML = '<div class="modal-empty">Could not load history.</div>'; }
    }

    async function restoreVersion(sha, btn) {
      btn.disabled = true; btn.textContent = 'Loading…';
      setPreviewWorking(true);
      try {
        const res = await apiFetch('/api/restore-version', { method: 'POST', body: JSON.stringify({ sha }) });
        const data = await res.json().catch(() => ({}));
        if (res.status === 401) { setTimeout(signOut, 200); return; }
        if (!res.ok) { addAssistant(data.error || `Restore failed (HTTP ${res.status}).`, { error: true }); return; }
        if (typeof data.html === 'string') setPreviewHtml(data.html);
        setCanRevert(false);
        overlay.classList.remove('open');
        addAssistant(`Loaded version ${sha.slice(0, 7)} into your draft. Review it, edit further, or publish.`, { time: timeNow() });
      } catch (err) { addAssistant('Could not restore that version. Try again.', { error: true }); }
      finally { btn.disabled = false; btn.textContent = 'Load into editor'; setPreviewWorking(false); }
    }
  </script>
</body>
</html>
