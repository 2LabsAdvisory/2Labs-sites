---
// login.astro — passwordless OTP sign-in for the 2Labs Sites editor.
// Two stages on one screen: email -> "Send code" -> 7-digit code ->
// "Verify & sign in". Calls this SWA's own /api/auth/* proxies (which forward
// to PassCard and enforce the allowlist), stores the returned session token in
// localStorage, and redirects to /dashboard.
import brand from '../../site-config/brand.json';
const TOKEN_KEY = '2labs_sites_token';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<title>Sign in — {brand.orgName} Sites</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{
    --amber:#F59F0A; --amber-dark:#D9870A; --amber-tint-strong:#FFFBEB;
    --ink:#1F242E; --ink-soft:#676F7E; --bg:#F8F7F6; --surface:#FFFFFF; --border:#E5E0DC;
    --red:#C0392B; --red-bg:#FBEAE8; --green:#2F8558;
    --shadow:0 1px 2px rgba(31,36,46,0.04), 0 10px 28px rgba(31,36,46,0.06);
  }
  *{box-sizing:border-box;}
  body{ margin:0; min-height:100vh; background:var(--bg); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; display:flex; align-items:center; justify-content:center; padding:24px; }
  h1{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.01em; }
  .card{ width:100%; max-width:400px; background:var(--surface); border:1px solid var(--border); border-radius:18px; box-shadow:var(--shadow); padding:32px 28px; }
  .brand-mark{ width:48px;height:48px;border-radius:50%; background:#F6EDE1; display:flex;align-items:center;justify-content:center; margin:0 auto 18px; }
  .brand-mark svg{ width:30px;height:30px; }
  h1{ font-size:21px; text-align:center; margin:0 0 6px; }
  .sub{ font-size:13.5px; color:var(--ink-soft); text-align:center; margin:0 0 22px; line-height:1.5; }
  label{ display:block; font-size:12px; font-weight:600; color:var(--ink-soft); margin:0 0 6px; }
  input{ width:100%; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-family:'Inter',sans-serif; font-size:15px; color:var(--ink); background:var(--bg); }
  input:focus{ outline:none; border-color:var(--amber); }
  input.code{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:0.4em; text-align:center; font-size:20px; font-weight:700; }
  .btn{ width:100%; margin-top:16px; border:none; border-radius:10px; padding:13px; font-family:'Inter',sans-serif; font-weight:600; font-size:14.5px; cursor:pointer; background:var(--amber); color:var(--ink); display:flex; align-items:center; justify-content:center; gap:8px; }
  .btn:hover{ background:var(--amber-dark); }
  .btn:disabled{ opacity:.55; cursor:not-allowed; }
  .msg{ font-size:12.5px; margin-top:14px; padding:10px 12px; border-radius:9px; display:none; }
  .msg.error{ display:block; background:var(--red-bg); color:var(--red); border:1px solid #EBC9C4; }
  .msg.info{ display:block; background:var(--amber-tint-strong); color:var(--amber-dark); border:1px solid #F3E3B8; }
  .linkbtn{ background:none; border:none; color:var(--ink-soft); font-size:12.5px; text-decoration:underline; cursor:pointer; margin-top:16px; display:block; width:100%; text-align:center; font-family:'Inter',sans-serif; }
  .spinner{ width:14px;height:14px;border-radius:50%; border:2px solid rgba(31,36,46,0.25); border-top-color:var(--ink); animation:spin .8s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg); } }
  .foot{ text-align:center; font-size:11px; color:var(--ink-soft); margin-top:22px; }
  .hidden{ display:none; }
</style>
</head>
<body>
  <div class="card">
    <div class="brand-mark">
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 46 C12 38 13 30 17 24 C19 21 22 19 25 19 C27 19 28 20.5 28 22.5 C28 25 26.5 26 25.5 28 C24 31 24 35 25 39 C26 43 27 46 27 46 Z" stroke="#1F242E" stroke-width="2" stroke-linejoin="round"/>
        <path d="M31 46 C29 37 30 28 35 22 C37.5 19 41 17 44 17 C46.5 17 48 18.7 48 21 C48 24 46 25.5 44.5 28 C42.5 31.5 42.5 36 43.5 40.5 C44.5 44 46 46 46 46 Z" fill="#F59F0A"/>
      </svg>
    </div>

    <h1 id="title">Sign in to {brand.orgName} Sites</h1>
    <p class="sub" id="subtitle">Enter your email and we'll send you a secure sign-in code — no password needed.</p>

    <!-- Stage 1: email -->
    <form id="emailForm">
      <label for="email">Email address</label>
      <input id="email" type="email" autocomplete="email" placeholder="you@2labs.ca" required />
      <button class="btn" id="sendBtn" type="submit">Send code</button>
    </form>

    <!-- Stage 2: code -->
    <form id="codeForm" class="hidden">
      <label for="code">Verification code</label>
      <input id="code" class="code" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="7" placeholder="•••••••" />
      <button class="btn" id="verifyBtn" type="submit">Verify &amp; sign in</button>
      <button class="linkbtn" id="backBtn" type="button">Use a different email</button>
    </form>

    <div class="msg" id="msg"></div>
    <div class="foot">2Labs Sites — proudly Canadian-owned 🍁</div>
  </div>

  <script define:vars={{ TOKEN_KEY }}>
    // Already signed in? Skip straight to the dashboard.
    if (localStorage.getItem(TOKEN_KEY)) location.replace('/dashboard');

    const emailForm = document.getElementById('emailForm');
    const codeForm = document.getElementById('codeForm');
    const emailInput = document.getElementById('email');
    const codeInput = document.getElementById('code');
    const sendBtn = document.getElementById('sendBtn');
    const verifyBtn = document.getElementById('verifyBtn');
    const backBtn = document.getElementById('backBtn');
    const title = document.getElementById('title');
    const subtitle = document.getElementById('subtitle');
    const msg = document.getElementById('msg');

    function showMsg(text, kind) { msg.textContent = text; msg.className = 'msg ' + kind; }
    function clearMsg() { msg.textContent = ''; msg.className = 'msg'; }
    function spin(btn, on, label) {
      btn.disabled = on;
      btn.innerHTML = on ? '<span class="spinner"></span>' : label;
    }

    async function postJson(path, payload) {
      const res = await fetch(path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      return { ok: res.ok, status: res.status, body };
    }

    emailForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMsg();
      const email = emailInput.value.trim();
      if (!email) return;
      spin(sendBtn, true, 'Send code');
      const { ok, body } = await postJson('/api/auth/request-code', { email });
      spin(sendBtn, false, 'Send code');
      if (!ok) { showMsg(body.error || 'Could not send a code. Try again.', 'error'); return; }
      // Move to code stage (response is deliberately generic for privacy).
      emailForm.classList.add('hidden');
      codeForm.classList.remove('hidden');
      title.textContent = 'Check your email';
      subtitle.textContent = `If ${email} is authorized, a sign-in code is on its way. Enter it below.`;
      showMsg('Code sent — check your inbox.', 'info');
      codeInput.focus();
    });

    codeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMsg();
      const email = emailInput.value.trim();
      const code = codeInput.value.trim();
      if (!code) return;
      spin(verifyBtn, true, 'Verify & sign in');
      const { ok, body } = await postJson('/api/auth/verify-code', { email, code });
      if (!ok || !body.token) {
        spin(verifyBtn, false, 'Verify & sign in');
        showMsg(body.error || 'That code is invalid or has expired.', 'error');
        return;
      }
      localStorage.setItem(TOKEN_KEY, body.token);
      location.replace('/dashboard');
    });

    backBtn.addEventListener('click', () => {
      clearMsg();
      codeForm.classList.add('hidden');
      emailForm.classList.remove('hidden');
      title.textContent = 'Sign in';
      subtitle.textContent = "Enter your email and we'll send you a secure sign-in code — no password needed.";
      codeInput.value = '';
      emailInput.focus();
    });
  </script>
</body>
</html>
