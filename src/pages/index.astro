---
// index.astro — the builder landing page served at 2labs.site/. Small, branded
// entry with a Sign in button. (Client sites live under sites/<slug>/, not here.)
import brand from '../../site-config/brand.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>2Labs Sites — AI website builder</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{ --amber:#F59F0A; --amber-dark:#D9870A; --amber-tint-strong:#FFFBEB; --ink:#1F242E; --ink-soft:#676F7E; --bg:#F8F7F6; --surface:#FFFFFF; --border:#E5E0DC; --shadow:0 1px 2px rgba(31,36,46,0.04), 0 10px 28px rgba(31,36,46,0.06); }
  *{box-sizing:border-box;}
  body{ margin:0; min-height:100vh; background:var(--bg); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; display:flex; flex-direction:column; }
  h1{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.02em; }
  header{ display:flex; align-items:center; justify-content:space-between; padding:20px 32px; }
  .brand{ display:flex; align-items:center; gap:11px; }
  .brand-mark{ width:38px;height:38px;border-radius:50%; overflow:hidden; flex-shrink:0; }
  .brand-mark img{ width:100%;height:100%; object-fit:cover; display:block; }
  .brand-name{ font-weight:800; font-size:17px; }
  .brand-name span{ color:var(--amber-dark); }
  .btn{ border:none; border-radius:10px; padding:11px 20px; font-family:'Inter',sans-serif; font-weight:600; font-size:14px; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; }
  .btn-primary{ background:var(--amber); color:var(--ink); } .btn-primary:hover{ background:var(--amber-dark); }
  .btn-ghost{ background:var(--surface); color:var(--ink); border:1px solid var(--border); }
  main{ flex:1; display:flex; align-items:center; justify-content:center; padding:24px; }
  .hero{ max-width:640px; text-align:center; }
  .eyebrow{ display:inline-block; background:var(--amber-tint-strong); color:var(--amber-dark); border:1px solid #F3E3B8; font-size:12.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:6px 12px; border-radius:100px; margin-bottom:22px; }
  .hero h1{ font-size:44px; line-height:1.1; margin:0 0 16px; }
  .hero h1 .accent{ color:var(--amber); }
  .hero p{ font-size:17px; line-height:1.6; color:var(--ink-soft); margin:0 0 30px; }
  .cta{ display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
  .cta .btn{ padding:13px 24px; font-size:15px; }
  footer{ text-align:center; padding:22px; font-size:12px; color:var(--ink-soft); }
  footer b{ color:var(--ink); }
</style>
</head>
<body>
  <header>
    <div class="brand">
      <div class="brand-mark"><img src="/logo.png" alt="2Labs" width="38" height="38" /></div>
      <div class="brand-name">2Labs<span>Sites</span></div>
    </div>
    <a class="btn btn-ghost" href="/login">Sign in</a>
  </header>

  <main>
    <div class="hero">
      <span class="eyebrow">AI Website Builder</span>
      <h1>Websites that help your organization <span class="accent">do more good</span>.</h1>
      <p>2Labs Sites builds and maintains fast, SEO-ready websites for mission-driven organizations — describe a change in plain language and publish when it looks right.</p>
      <div class="cta">
        <a class="btn btn-primary" href="/login">Sign in to your dashboard →</a>
      </div>
    </div>
  </main>

  <footer>2Labs Sites — <b>powered by {brand.orgName}</b> · proudly Canadian-owned 🍁</footer>
</body>
</html>
