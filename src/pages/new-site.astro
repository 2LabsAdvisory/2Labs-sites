          <div class="team-row waiting" data-team="0"><div class="team-ico">🧭</div><div class="team-main"><div class="team-role">Senior UX Designer</div><div class="team-task">Mapping site structure, navigation &amp; user flows</div></div><div class="team-status"><span class="spinner"></span> Queued</div></div>
          <div class="team-row waiting" data-team="1"><div class="team-ico">🎨</div><div class="team-main"><div class="team-role">Senior Web Designer</div><div class="team-task">Applying your brand, layouts &amp; custom imagery</div></div><div class="team-status"><span class="spinner"></span> Queued</div></div>
          <div class="team-row waiting" data-team="2"><div class="team-ico">⚙️</div><div class="team-main"><div class="team-role">Senior Web Developer</div><div class="team-task">Building responsive pages · W3C valid · WCAG 2.2 AA</div></div><div class="team-status"><span class="spinner"></span> Queued</div></div>
          <div class="team-row waiting" data-team="3"><div class="team-ico">✍️</div><div class="team-main"><div class="team-role">Senior Content &amp; AI Strategist</div><div class="team-task">Writing your content · SEO + LLM findability</div></div><div class="team-status"><span class="spinner"></span> Queued</div></div>
        </div>
        <div class="center" id="buildDone" style="display:none;">
          <div class="done-icon">✓</div>
          <h2 style="margin:0 0 6px;">Your site is ready</h2>
          <p class="sub" style="margin:0 auto; max-width:400px;">A staging site you can shape in the editor. Brand, content and structure are all editable.</p>
          <div class="saved-note">◈ Brand system saved to Settings → Brand Guidelines</div>
          <div class="done-actions">
            <a class="btn btn-primary btn-lg" id="openEditorBtn" href="/dashboard">Go to your sites →</a>
          </div>
        </div>
      </div>

      <div class="card-actions" id="cardActions">
        <button class="btn btn-ghost" id="backBtn" onclick="goTo(current-1)">← Back</button>
        <button class="btn btn-primary" id="nextBtn" onclick="onNext()">Continue →</button>
      </div>
    </div>
  </div>

<script is:inline>
  const TOKEN_KEY = '2labs_sites_token';
  const authToken = () => localStorage.getItem(TOKEN_KEY);
  function apiFetch(path, opts = {}) {
    return fetch(path, { ...opts, headers: { 'Content-Type': 'application/json', 'x-2labs-session': authToken() || '', 'Authorization': 'Bearer ' + (authToken() || ''), ...(opts.headers || {}) } });
  }

  // Starter palettes (the AI Brand Designer will replace these in Part B).
  const PALETTES = {
    import: {
      core:[{name:'Primary',hex:'#1F3A5F'},{name:'Secondary',hex:'#F5A623'},{name:'Surface',hex:'#F7F5F1'}],
      accent:[{name:'Teal',hex:'#2E9E8F',rec:true},{name:'Coral',hex:'#E8654E',rec:true}],
      semantic:[{name:'Success',hex:'#2F8558'},{name:'Warning',hex:'#E8A317'},{name:'Error',hex:'#D64545'},{name:'Info',hex:'#2F6FB0'}],
      neutral:[{name:'Ink',hex:'#1F2430'},{name:'Slate',hex:'#3D4351'},{name:'Muted',hex:'#676F7E'},{name:'Silver',hex:'#A7ADB8'},{name:'Line',hex:'#E2DDD7'},{name:'Paper',hex:'#F7F5F1'}]
    },
    blank: {
      core:[{name:'Primary',hex:'#2F5DA8'},{name:'Secondary',hex:'#F2A93B'},{name:'Surface',hex:'#F7F6F4'}],
      accent:[{name:'Teal',hex:'#2BB0A0',rec:true},{name:'Coral',hex:'#EC6A55',rec:true}],
      semantic:[{name:'Success',hex:'#2F8558'},{name:'Warning',hex:'#E8A317'},{name:'Error',hex:'#D64545'},{name:'Info',hex:'#2F6FB0'}],
      neutral:[{name:'Ink',hex:'#1F2430'},{name:'Slate',hex:'#3D4351'},{name:'Muted',hex:'#676F7E'},{name:'Silver',hex:'#A7ADB8'},{name:'Line',hex:'#E4E0DB'},{name:'Paper',hex:'#F7F6F4'}]
    }
  };
  PALETTES.describe = JSON.parse(JSON.stringify(PALETTES.blank));
  const CONTENT = { import:{org:'',mission:'',offers:[],goal:null}, blank:{org:'',mission:'',offers:[],goal:null}, describe:{org:'',mission:'',offers:[],goal:null} };
  const GOALS = ['Donate','Volunteer','Book / Contact us','Sign up','Buy'];

  let mode = 'describe';
  let current = 1;
  const total = 5;
  let createdSlug = null;
  let interpretation = null; // Brief Interpreter output (describe path)

  function applyMode(){
    document.body.dataset.mode = mode;
    document.querySelectorAll('.if-import, .inline-import').forEach(el=>{ el.style.display = (mode==='import') ? '' : 'none'; });
    document.querySelectorAll('.if-blank, .inline-blank').forEach(el=>{ el.style.display = (mode==='blank') ? '' : 'none'; });
  }
  function setMode(m){
    mode = m; applyMode();
    for (const [id, mm] of [['choiceImport','import'],['choiceDescribe','describe'],['choiceBlank','blank']]) document.getElementById(id).classList.toggle('selected', m===mm);
    document.getElementById('importPanel').classList.toggle('hidden', m!=='import');
    document.getElementById('describePanel').classList.toggle('hidden', m!=='describe');
    document.getElementById('blankPanel').classList.toggle('hidden', m!=='blank');
  }

  // ---- Describe path: references + Brief Interpreter + Refine ----
  let describeInput = null;
  const esc = (s) => String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  function addRefRow(url='', note=''){
    const wrap=document.createElement('div'); wrap.className='ref-row';
    const u=document.createElement('input'); u.type='text'; u.className='ref-url'; u.placeholder='https://a-site-you-like.com'; u.value=url;
    const n=document.createElement('input'); n.type='text'; n.className='ref-note'; n.placeholder='what you like (optional)'; n.value=note;
    const x=document.createElement('button'); x.type='button'; x.className='ref-x'; x.textContent='×'; x.onclick=()=>wrap.remove();
    wrap.append(u,n,x); document.getElementById('refRows').appendChild(wrap);
  }
  const collectRefs=()=>[...document.querySelectorAll('#refRows .ref-row')].map(r=>({url:r.querySelector('.ref-url').value.trim(),note:r.querySelector('.ref-note').value.trim()})).filter(r=>r.url);

  async function generateBrief(){
    const desc=document.getElementById('descInput').value.trim();
    if(!desc){ document.getElementById('descInput').focus(); return; }
    const btn=document.getElementById('describeBtn'); btn.disabled=true; btn.innerHTML='<span class="spinner"></span> Reading your brief…';
    describeInput={ description:desc, references:collectRefs(), style_notes:document.getElementById('styleInput').value.trim() };
    try {
      const res=await apiFetch('/api/interpret-brief',{method:'POST',body:JSON.stringify(describeInput)});
      const data=await res.json().catch(()=>({}));
      if(res.status===401){ location.replace('/login'); return; }
      if(data.status!=='ok'||!data.interpretation) throw new Error('interpret failed');
      interpretation=data.interpretation;
      const c=CONTENT.describe;
      if(interpretation.org_name) c.org=interpretation.org_name;
      if(interpretation.summary) c.mission=interpretation.summary;
      if(Array.isArray(interpretation.offers)&&interpretation.offers.length) c.offers=interpretation.offers.slice();
      if(interpretation.primary_goal) c.goal=interpretation.primary_goal;
      renderRefine(); showRefine();
    } catch(e){
      // Fall back: proceed with the description as the mission, skip refine.
      interpretation={ archetype:'', primary_goal:null, summary:desc, extracted_facts:[], must_have_sections:[], gaps:[], clarifying_questions:[] };
      CONTENT.describe.mission=desc; goTo(2);
    } finally { btn.disabled=false; btn.innerHTML='Generate my brief →'; }
  }

  function renderRefine(){
    const it=interpretation||{};
    document.getElementById('refineRecap').textContent = it.rationale || ('A '+(it.archetype||'site')+(it.primary_goal?(' built to '+it.primary_goal.toLowerCase()):'')+'.');
    const facts=it.extracted_facts||[]; const fw=document.getElementById('refineFacts'); const fl=document.getElementById('refineFactList');
    fl.innerHTML=''; fw.style.display=facts.length?'block':'none';
    facts.forEach(f=>{ const s=document.createElement('span'); s.className='fact-chip'; s.innerHTML='<b>'+esc(f.label)+':</b> '+esc(f.value); fl.appendChild(s); });
    const qs=(it.clarifying_questions||[]).slice(0,5); const qc=document.getElementById('refineQuestions'); qc.innerHTML='';
    if(!qs.length){ const d=document.createElement('div'); d.className='field-hint'; d.style.margin='6px 0 0'; d.textContent='Got everything I need — continue when ready.'; qc.appendChild(d); }
    qs.forEach(q=>{
      const box=document.createElement('div'); box.className='refine-q'; box.dataset.qid=q.id;
      const qt=document.createElement('div'); qt.className='q'; qt.textContent=q.question; box.appendChild(qt);
      if(q.kind==='choice'&&Array.isArray(q.options)){
        const row=document.createElement('div'); row.className='chip-row'; row.style.marginTop='0';
        q.options.forEach(o=>{ const chip=document.createElement('span'); chip.className='chip goal'; chip.textContent=o; chip.onclick=()=>{ [...row.children].forEach(c=>c.classList.remove('goal-sel')); chip.classList.add('goal-sel'); box.dataset.answer=o; }; row.appendChild(chip); });
        box.appendChild(row);
      } else { const inp=document.createElement('input'); inp.type='text'; inp.placeholder='Your answer (optional)'; inp.oninput=()=>{ box.dataset.answer=inp.value.trim(); }; box.appendChild(inp); }
      qc.appendChild(box);
    });
  }
  function showRefine(){
    document.querySelectorAll('.step-panel').forEach(p=>p.classList.remove('active'));
    document.querySelector('.step-panel[data-panel="refine"]').classList.add('active');
    document.getElementById('cardActions').style.display='none';
    window.scrollTo({top:0,behavior:'smooth'});
  }
  function finishRefine(){
    const answers={};
    document.querySelectorAll('#refineQuestions .refine-q').forEach(b=>{ if(b.dataset.answer) answers[b.dataset.qid]=b.dataset.answer; });
    if(interpretation) interpretation.answers=answers;
    goTo(2);
  }

  function makeSwatch(c){
    const wrap=document.createElement('div'); wrap.className='swatch'+(c.rec?' rec':'');
    const color=document.createElement('input'); color.type='color'; color.className='swatch-color'; color.value=c.hex;
    const hex=document.createElement('input'); hex.type='text'; hex.className='swatch-hex'; hex.value=c.hex; hex.maxLength=7;
    const name=document.createElement('div'); name.className='swatch-name'; name.textContent=c.name;
    color.addEventListener('input',()=>{ hex.value=color.value.toUpperCase(); c.hex=color.value; });
    hex.addEventListener('change',()=>{ if(/^#[0-9a-fA-F]{6}$/.test(hex.value)){ color.value=hex.value; c.hex=hex.value; } });
    wrap.append(color,hex,name); return wrap;
  }
  function renderColors(){
    const p = PALETTES[mode];
    const map = { coreRow:p.core, accentRow:p.accent, semanticRow:p.semantic, neutralRow:p.neutral };
    for(const id in map){ const row=document.getElementById(id); row.innerHTML=''; map[id].forEach(c=>row.appendChild(makeSwatch(c))); }
  }

  // ---- Studio: Brand Extraction + Senior Brand Designer (Build Brief §3.1) ----
  const brandState = { import:null, blank:null };
  function up(hex){ const h=String(hex||'').replace('#','').trim(); return /^[0-9a-fA-F]{6}$/.test(h) ? ('#'+h).toUpperCase() : '#000000'; }
  function setBrandBusy(v){
    document.getElementById('brandBusy').style.display = v ? 'flex' : 'none';
    document.getElementById('colorBlock').style.display = v ? 'none' : '';
    const next = document.getElementById('nextBtn'); if(next) next.disabled = v;
  }
  function applyBrand(data){
    const c = data.brand.colors || {};
    PALETTES[mode] = {
      core:(c.core||[]).map(x=>({name:x.name,hex:up(x.hex)})),
      accent:(c.accents||[]).map(x=>({name:x.name,hex:up(x.hex),rec:true})),
      semantic:(c.semantic||[]).map(x=>({name:x.name,hex:up(x.hex)})),
      neutral:(c.neutral||[]).map(x=>({name:x.name,hex:up(x.hex)}))
    };
    const t = data.brand.typography || {};
    if(t.heading) document.getElementById('headFont').textContent = t.heading;
    if(t.body) document.getElementById('bodyFont').textContent = t.body;
    if(data.rationale){ document.getElementById('calloutImport').textContent = data.rationale; document.getElementById('calloutBlank').textContent = data.rationale; }
    if(data.a11y){
      const r = (data.a11y.report||[]).map(x=>x.ratio).filter(Boolean).sort((a,b)=>a-b)[0];
      document.getElementById('a11yNote').textContent = data.a11y.passed
        ? ('♿ All text/background pairings pass WCAG 2.2 AA' + (r?(' — lowest '+r+':1'):''))
        : '⚠ Some pairings need adjustment for WCAG 2.2 AA — tweak the hex values';
    }
    renderColors();
  }
  async function ensureBrand(){
    if(brandState[mode]){ applyBrand(brandState[mode]); return; }
    setBrandBusy(true);
    try{
      const payload = mode==='import'
        ? { mode, url:(document.getElementById('urlInput').value||'').trim() }
        : mode==='describe'
          ? { mode, org:CONTENT.describe.org, mission:CONTENT.describe.mission, offers:CONTENT.describe.offers, goal:CONTENT.describe.goal,
              description:(describeInput&&describeInput.description)||'', style_notes:(describeInput&&describeInput.style_notes)||'',
              inspiration:(interpretation&&interpretation.inspiration)||null, archetype:(interpretation&&interpretation.archetype)||'' }
          : { mode, org:CONTENT[mode].org, mission:CONTENT[mode].mission, offers:[], goal:CONTENT[mode].goal };
      const res = await apiFetch('/api/generate-brand', { method:'POST', body: JSON.stringify(payload) });
      const data = await res.json().catch(()=>({}));
      if(data.status==='ok' && data.brand && data.brand.colors){
        brandState[mode]=data; applyBrand(data);
        // Import: prefill Step 3 content from what the scan extracted.
        if(mode==='import' && data.content){
          const c=data.content;
          if(c.org_name) CONTENT.import.org=c.org_name;
          if(c.mission) CONTENT.import.mission=c.mission;
          if(Array.isArray(c.offers)&&c.offers.length) CONTENT.import.offers=c.offers;
          updateOrgPill();
        }
      }
      else { renderColors(); } // graceful fallback to the starter palette
    }catch(e){ renderColors(); }
    finally{ setBrandBusy(false); }
  }

  function makeChip(text){ const c=document.createElement('span'); c.className='chip'; c.contentEditable='true'; c.textContent=text; return c; }
  function renderContent(){
    const d = CONTENT[mode];
    const on=document.getElementById('orgName'); on.value=d.org; on.placeholder='e.g. Riverside Youth Outreach';
    const mi=document.getElementById('mission'); mi.value=d.mission; mi.placeholder='In one or two sentences, what does your organization do and who for?';
    const offerRow=document.getElementById('offerRow'); offerRow.innerHTML='';
    d.offers.forEach(o=>offerRow.appendChild(makeChip(o)));
    const add=document.createElement('span'); add.className='chip add'; add.textContent='+ Add';
    add.onclick=()=>{ const c=makeChip('New offering'); offerRow.insertBefore(c,add); c.focus(); const r=document.createRange(); r.selectNodeContents(c); const s=getSelection(); s.removeAllRanges(); s.addRange(r); };
    offerRow.appendChild(add);
    const goalRow=document.getElementById('goalRow'); goalRow.innerHTML='';
    GOALS.forEach(g=>{ const chip=document.createElement('span'); chip.className='chip goal'+(d.goal===g?' goal-sel':''); chip.textContent=g; chip.onclick=()=>{ CONTENT[mode].goal=g; renderContent(); }; goalRow.appendChild(chip); });
    on.oninput=()=>{ d.org=on.value; updateOrgPill(); };
    mi.oninput=()=>{ d.mission=mi.value; };
  }
  function updateOrgPill(){
    const org = (CONTENT[mode].org || '').trim();
    document.getElementById('orgPillName').textContent = org || 'New site';
    document.getElementById('orgAvatar').textContent = org ? org.split(/\s+/).slice(0,2).map(w=>w[0]).join('').toUpperCase() : '2L';
  }

  function renderSummary(){
    const p = PALETTES[mode];
    const sw=document.getElementById('summarySwatches'); sw.innerHTML='';
    [...p.core, ...p.accent].forEach(c=>{ const i=document.createElement('i'); i.style.background=c.hex; sw.appendChild(i); });
    const t = (brandState[mode] && brandState[mode].brand && brandState[mode].brand.typography) || {};
    document.getElementById('summaryFonts').innerHTML='<span>Fonts:</span> '+(t.heading||'Plus Jakarta Sans')+' · '+(t.body||'Inter');
    const org=(document.getElementById('orgName').value||'').trim()||'(your org)';
    const offerCount=document.querySelectorAll('#offerRow .chip:not(.add)').length;
    const goal=CONTENT[mode].goal||'(not set)';
    document.getElementById('summaryOrg').innerHTML='<span>Org:</span> '+org;
    document.getElementById('summaryOffer').innerHTML='<span>Offers:</span> '+offerCount+' program'+(offerCount===1?'':'s');
    document.getElementById('summaryGoal').innerHTML='<span>Goal:</span> '+goal;
  }

  // Assemble the Wizard Brief (Build Brief §2.3) — the object the Studio consumes.
  function buildBrief(){
    const p = PALETTES[mode];
    const offers = [...document.querySelectorAll('#offerRow .chip:not(.add)')].map(c=>c.textContent.trim()).filter(Boolean);
    const map = (a)=>a.map(c=>({ name:c.name, hex:c.hex, ...(c.rec?{ai_recommended:true}:{}) }));
    const bs = brandState[mode];
    const t = (bs && bs.brand && bs.brand.typography) || {};
    return {
      mode,
      source: { url: (document.getElementById('urlInput').value||'').trim(), scanned: !!(bs && bs.scanned) },
      brand: {
        colors: { core:map(p.core), accents:map(p.accent), semantic:map(p.semantic), neutral:map(p.neutral) },
        typography: { heading:t.heading||'Plus Jakarta Sans', body:t.body||'Inter', scale:{h1:32,h2:24,h3:19,body:16,small:13} },
        voice: (bs && bs.brand && bs.brand.voice) || [],
        a11y: (bs && bs.a11y) || { standard:'WCAG 2.2 AA', passed:true }
      },
      content: {
        org_name: (document.getElementById('orgName').value||'').trim(),
        mission: (document.getElementById('mission').value||'').trim(),
        offers,
        primary_goal: CONTENT[mode].goal || null
      },
      ...(mode==='describe' ? {
        input: describeInput || {},
        interpretation: interpretation || null
      } : {})
    };
  }

  // Create the site record. Full AI generation (the Studio, Part B) is the next
  // phase; for now we persist the brief with the new site and open the editor.
  async function createSite(){
    const brief = buildBrief();
    const name = brief.content.org_name || 'New site';
    const domain = brief.source.url ? brief.source.url.replace(/^https?:\/\//,'').replace(/\/+$/,'') : '';
    try {
      const res = await apiFetch('/api/save-site', { method:'POST', body: JSON.stringify({ name, domain, brief }) });
      const data = await res.json().catch(()=>({}));
      if (data.status==='ok' && data.site) createdSlug = data.site.slug;
    } catch(e) { /* handled by the caller */ }
  }

  // Run the real Studio pipeline (plan → page-by-page), driving the Step 5 UI
  // from actual progress. Each call is bounded so nothing hits the timeout.
  let studioRunning = false;
  async function runBuild(){
    if (studioRunning) return; studioRunning = true;
    document.getElementById('buildHead').style.display='block';
    document.getElementById('teamList').style.display='block';
    document.getElementById('buildDone').style.display='none';
    const rows = [...document.querySelectorAll('#teamList .team-row')];
    const setRow = (i, state, txt) => {
      const r = rows[i]; if (!r) return;
      r.className = 'team-row' + (state === 'waiting' ? ' waiting' : (state === 'done' ? ' done' : ''));
      const st = r.querySelector('.team-status');
      if (state === 'done') st.innerHTML = '<span class="check">✓</span> Done';
      else if (state === 'working') st.innerHTML = '<span class="spinner"></span> ' + (txt || 'Working…');
      else st.innerHTML = '<span class="spinner"></span> Queued';
    };
    rows.forEach((r, i) => setRow(i, 'waiting'));

    await createSite();
    if (!createdSlug) { setRow(0, 'working', 'Something went wrong — try again'); studioRunning = false; return; }

    try {
      setRow(0, 'working', 'Mapping your site…');
      const planRes = await apiFetch('/api/generate-plan', { method: 'POST', body: JSON.stringify({ site: createdSlug }) });
      const planData = await planRes.json().catch(() => ({}));
      if (planData.status !== 'ok' || !Array.isArray(planData.pages) || !planData.pages.length) throw new Error('plan failed');
      setRow(0, 'done');
      const pages = planData.pages;
      setRow(1, 'working', 'Designing…'); setRow(3, 'working', 'Writing content…');
      for (let i = 0; i < pages.length; i++) {
        setRow(2, 'working', 'Building ' + (i + 1) + '/' + pages.length + ': ' + pages[i].title);
        try { await (await apiFetch('/api/generate-page', { method: 'POST', body: JSON.stringify({ site: createdSlug, page: pages[i], pages }) })).json(); }
        catch (e) { /* skip a page that failed; keep building the rest */ }
      }
      setRow(1, 'done'); setRow(2, 'done'); setRow(3, 'done');
    } catch (e) {
      // Fallback so the site is never empty: a templated starter.
      try { await apiFetch('/api/seed-site', { method: 'POST', body: JSON.stringify({ site: createdSlug }) }); } catch (_) {}
      rows.forEach((r, i) => setRow(i, 'done'));
    }

    const link = document.getElementById('openEditorBtn');
    link.href = '/editor?site=' + encodeURIComponent(createdSlug);
    link.textContent = 'Open in Editor →';
    document.getElementById('buildHead').style.display='none';
    document.getElementById('teamList').style.display='none';
    document.getElementById('buildDone').style.display='block';
    studioRunning = false;
  }

  function goTo(n){
    if(n<1)n=1; if(n>total)n=total; current=n; render();
    if(n===2) ensureBrand();
    if(n===3){ renderContent(); updateOrgPill(); }
    if(n===4) renderSummary();
    if(n===5) runBuild();
    window.scrollTo({top:0,behavior:'smooth'});
  }
  function onNext(){ if(current<total) goTo(current+1); }
  function render(){
    document.querySelectorAll('.step').forEach(s=>{ const n=parseInt(s.dataset.step); s.classList.remove('active','done'); if(n<current)s.classList.add('done'); if(n===current)s.classList.add('active'); });
    document.querySelectorAll('.step-panel').forEach(p=>{ p.classList.toggle('active', parseInt(p.dataset.panel)===current); });
    const actions=document.getElementById('cardActions'); const next=document.getElementById('nextBtn');
    if(current===1||current===5){ actions.style.display='none'; return; }
    actions.style.display='flex';
    if(current===4){ next.textContent='Generate my site →'; next.disabled=!document.getElementById('confirmChk').checked; next.onclick=()=>goTo(5); }
    else { next.textContent='Continue →'; next.disabled=false; next.onclick=onNext; }
  }
  document.getElementById('confirmChk').addEventListener('change', function(){ document.getElementById('nextBtn').disabled = !this.checked; });

  document.getElementById('addRefBtn').onclick=()=>addRefRow();
  addRefRow();
  setMode('describe');
  render();
</script>

</body>
</html>
