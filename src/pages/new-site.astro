---
// new-site.astro — the New Site Wizard (Build Brief Part A). 5 steps, two modes
// (import an existing site / start blank). Assembles the "Wizard Brief" the AI
// Studio will consume (Part B), creates the site record on completion, and hands
// off to the editor. Faithful to client_onboarding mockup.
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<script is:inline>if(!localStorage.getItem('2labs_sites_token'))location.replace('/login');</script>
<title>New site — 2Labs Sites</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style is:global>
  :root{
    --amber:#F59F0A; --amber-dark:#D9870A; --amber-tint:rgba(245,159,10,0.08); --amber-tint-strong:#FFFBEB;
    --ink:#1F242E; --ink-soft:#676F7E; --bg:#F8F7F6; --surface:#FFFFFF; --border:#E5E0DC;
    --green:#2F8558; --green-bg:#EAF6EF; --violet:#6D5AE0; --violet-bg:#F1EFFC;
    --radius:16px; --shadow:0 1px 2px rgba(31,36,46,0.04), 0 10px 28px rgba(31,36,46,0.06);
  }
  *{box-sizing:border-box;}
  html,body{ height:100%; }
  body{ margin:0; background:var(--bg); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; min-height:100vh; display:flex; flex-direction:column; }
  h1,h2,h3,h4,.display{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.01em; }
  .mono{ font-family:'IBM Plex Mono',monospace; }

  .topbar{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:16px 24px; border-bottom:1px solid var(--border); background:var(--surface); }
  .brand{ display:flex; align-items:center; gap:10px; }
  .brand-mark{ width:30px;height:30px;border-radius:50%; overflow:hidden; }
  .brand-mark img{ width:100%;height:100%; object-fit:cover; display:block; }
  .brand-name{ font-weight:700; font-size:15px; }
  .org-pill{ display:flex; align-items:center; gap:8px; background:var(--surface); border:1px solid var(--border); padding:5px 13px 5px 5px; border-radius:100px; font-size:12.5px; font-weight:500; }
  .org-avatar{ width:24px;height:24px;border-radius:50%; background:var(--amber); display:flex;align-items:center;justify-content:center; color:var(--ink);font-size:10.5px;font-weight:700; }
  .close-x{ color:var(--ink-soft); font-size:20px; cursor:pointer; text-decoration:none; }

  .wrap{ flex:1; display:flex; flex-direction:column; align-items:center; padding:34px 20px 70px; }

  .stepper{ display:flex; align-items:center; gap:6px; margin-bottom:34px; max-width:720px; width:100%; }
  .step{ display:flex; align-items:center; gap:8px; }
  .step.grow{ flex:1; }
  .step-dot{ width:27px;height:27px;border-radius:50%; flex-shrink:0; display:flex;align-items:center;justify-content:center; font-size:11.5px; font-weight:700; font-family:'Plus Jakarta Sans',sans-serif; background:var(--surface); border:1.5px solid var(--border); color:var(--ink-soft); transition:.2s; }
  .step-label{ font-size:11.5px; font-weight:600; color:var(--ink-soft); white-space:nowrap; display:none; }
  .step-line{ flex:1; height:1.5px; background:var(--border); min-width:14px; }
  .step.done .step-dot{ background:var(--ink); border-color:var(--ink); color:var(--amber); }
  .step.active .step-dot{ background:var(--amber); border-color:var(--amber); color:var(--ink); }
  .step.active .step-label{ display:block; color:var(--ink); }
  @media(min-width:720px){ .step-label{ display:block; } }

  .card{ background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); width:100%; max-width:600px; padding:36px; }
  .card.wide{ max-width:660px; }
  .eyebrow{ font-size:11.5px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--amber-dark); margin-bottom:8px; }
  .card h2{ font-size:23px; margin:0 0 8px; }
  .card > p.sub{ font-size:13.5px; color:var(--ink-soft); margin:0 0 24px; line-height:1.5; }

  .field{ margin-bottom:18px; }
  .field label{ display:block; font-size:12.5px; font-weight:600; margin-bottom:6px; }
  .field .req{ color:var(--amber-dark); }
  .field input[type=text], .field textarea{ width:100%; border:1px solid var(--border); border-radius:10px; padding:11px 13px; font-family:'Inter',sans-serif; font-size:13.5px; color:var(--ink); background:var(--bg); }
  .field input:focus, .field textarea:focus{ outline:none; border-color:var(--amber); background:#fff; }
  .field textarea{ resize:vertical; min-height:82px; line-height:1.5; }
  .field-hint{ font-size:11.5px; color:var(--ink-soft); margin-top:5px; }
  .url-row{ display:flex; gap:8px; } .url-row input{ flex:1; }

  .btn{ border:none; border-radius:10px; padding:12px 20px; font-family:'Inter',sans-serif; font-weight:600; font-size:13.5px; cursor:pointer; display:inline-flex; align-items:center; gap:8px; text-decoration:none; }
  .btn-primary{ background:var(--amber); color:var(--ink); }
  .btn-primary:hover{ background:var(--amber-dark); }
  .btn-primary:disabled{ opacity:.45; cursor:not-allowed; }
  .btn-ghost{ background:transparent; color:var(--ink-soft); border:1px solid var(--border); }
  .btn-ghost:hover{ color:var(--ink); }
  .btn-lg{ padding:14px 26px; font-size:14.5px; }
  .card-actions{ display:flex; justify-content:space-between; align-items:center; margin-top:26px; }

  .choice-grid{ display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:22px; }
  .choice-grid.three{ grid-template-columns:repeat(3,1fr); }
  @media(max-width:560px){ .choice-grid.three{ grid-template-columns:1fr; } }
  .choice h4{ font-size:14px; } .choice p{ font-size:12px; }
  .ref-row{ display:flex; gap:8px; margin-bottom:8px; }
  .ref-row input.ref-url{ flex:1; } .ref-row input.ref-note{ flex:1; }
  .ref-row .ref-x{ border:1px solid var(--border); background:var(--surface); border-radius:9px; width:36px; color:var(--ink-soft); cursor:pointer; flex-shrink:0; }
  .refine-q{ border:1px solid var(--border); border-radius:12px; padding:14px 16px; margin-bottom:12px; }
  .refine-q .q{ font-size:13px; font-weight:600; margin-bottom:8px; }
  .refine-q input{ width:100%; border:1px solid var(--border); border-radius:9px; padding:9px 12px; font-family:'Inter',sans-serif; font-size:13px; background:var(--bg); color:var(--ink); }
  .refine-q input:focus{ outline:none; border-color:var(--amber); background:#fff; }
  .fact-chip{ background:var(--green-bg); color:var(--green); border:1px solid #CFE9D8; font-size:11.5px; font-weight:600; padding:5px 11px; border-radius:100px; }
  .fact-chip b{ font-weight:700; }
  .choice{ border:1.5px solid var(--border); border-radius:14px; padding:20px; cursor:pointer; transition:.15s; background:var(--surface); position:relative; }
  .choice:hover{ border-color:var(--amber); box-shadow:var(--shadow); }
  .choice.selected{ border-color:var(--amber); background:var(--amber-tint-strong); }
  .choice-ico{ width:40px;height:40px;border-radius:11px; background:var(--amber-tint-strong); display:flex;align-items:center;justify-content:center; font-size:20px; margin-bottom:12px; }
  .choice h4{ margin:0 0 5px; font-size:15px; }
  .choice p{ margin:0; font-size:12.5px; color:var(--ink-soft); line-height:1.45; }
  .choice-tag{ position:absolute; top:14px; right:14px; font-size:10px; font-weight:700; color:var(--amber-dark); background:#fff; border:1px solid #F3E3B8; padding:3px 8px; border-radius:100px; }

  .import-panel{ border:1px solid var(--border); border-radius:12px; padding:18px; background:var(--bg); margin-bottom:6px; }
  .import-panel.hidden{ display:none; }
  .import-visual{ display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:16px; }
  .import-visual .old-site, .import-visual .new-site{ width:96px; height:60px; border-radius:8px; background:#fff; border:1px solid var(--border); position:relative; overflow:hidden; }
  .import-visual .old-site::before{ content:""; position:absolute; top:0; left:0; right:0; height:12px; background:#EFEDEA; }
  .import-visual .old-site::after{ content:""; position:absolute; top:20px; left:9px; right:9px; height:7px; background:#DEDAD3; border-radius:3px; }
  .import-visual .new-site{ border-color:var(--amber); }
  .import-visual .new-site::before{ content:""; position:absolute; top:0; left:0; right:0; height:12px; background:var(--amber-tint-strong); }
  .import-visual .new-site::after{ content:""; position:absolute; top:20px; left:9px; right:9px; height:7px; background:var(--amber); opacity:.6; border-radius:3px; }
  .import-visual .arrow{ font-size:18px; color:var(--amber-dark); }

  .ai-callout{ display:flex; gap:12px; align-items:flex-start; background:var(--violet-bg); border:1px solid #E1DCF7; border-radius:12px; padding:14px 16px; margin-bottom:22px; }
  .ai-avatar{ width:32px;height:32px;border-radius:9px; flex-shrink:0; background:linear-gradient(135deg,#7C6BEA,#5A47C8); color:#fff; display:flex;align-items:center;justify-content:center; font-size:16px; }
  .ai-callout .ai-name{ font-size:11px; font-weight:700; color:var(--violet); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px; }
  .ai-callout p{ margin:0; font-size:12.5px; color:var(--ink); line-height:1.5; }
  .ai-badge{ display:inline-flex; align-items:center; gap:4px; font-size:9.5px; font-weight:700; color:var(--violet); background:#fff; border:1px solid #E1DCF7; padding:2px 7px; border-radius:100px; text-transform:uppercase; letter-spacing:.04em; vertical-align:middle; }
  .found-banner{ display:flex; align-items:center; gap:8px; background:var(--green-bg); color:var(--green); font-size:12.5px; font-weight:600; padding:9px 13px; border-radius:9px; margin-bottom:20px; }

  .review-block{ border:1px solid var(--border); border-radius:12px; padding:16px 16px 18px; margin-bottom:14px; }
  .review-block-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
  .review-block-head h4{ margin:0; font-size:13px; display:flex; align-items:center; gap:8px; }
  .block-note{ font-size:11.5px; color:var(--ink-soft); margin:0 0 14px; line-height:1.45; }
  .edit-link{ font-size:11.5px; color:var(--amber-dark); font-weight:600; cursor:pointer; }

  .color-group{ margin-bottom:14px; } .color-group:last-child{ margin-bottom:0; }
  .color-group-label{ font-size:11px; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.05em; margin-bottom:9px; display:flex; align-items:center; gap:7px; }
  .swatch-row{ display:flex; gap:10px; flex-wrap:wrap; }
  .swatch{ text-align:center; width:60px; }
  .swatch-color{ width:100%; height:46px; border-radius:10px; border:1px solid rgba(0,0,0,0.08); margin-bottom:5px; padding:0; cursor:pointer; -webkit-appearance:none; appearance:none; }
  .swatch-color::-webkit-color-swatch-wrapper{ padding:0; }
  .swatch-color::-webkit-color-swatch{ border:none; border-radius:9px; }
  .swatch-hex{ width:100%; border:none; background:transparent; text-align:center; font-size:9.5px; color:var(--ink-soft); font-family:'IBM Plex Mono',monospace; padding:2px 0; text-transform:uppercase; }
  .swatch-hex:focus{ outline:none; color:var(--ink); background:var(--amber-tint-strong); border-radius:5px; }
  .swatch-name{ font-size:9.5px; color:var(--ink); font-weight:600; margin-top:1px; }
  .swatch.rec .swatch-color{ box-shadow:0 0 0 2px #fff, 0 0 0 3.5px var(--violet); }
  .a11y-note{ display:flex; align-items:center; gap:7px; margin-top:14px; font-size:11px; color:var(--green); background:var(--green-bg); padding:7px 11px; border-radius:8px; }

  .font-row{ display:flex; gap:26px; flex-wrap:wrap; }
  .font-sample b{ display:block; font-size:16px; color:var(--ink); margin-bottom:2px; }
  .font-sample .fs-head{ font-family:'Plus Jakarta Sans',sans-serif; }
  .font-sample .fs-body{ font-family:'Inter',sans-serif; }
  .font-sample span{ font-size:11.5px; color:var(--ink-soft); }

  .logo-row{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .logo-thumb{ width:44px; height:44px; border-radius:9px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); overflow:hidden; }
  .logo-thumb.light{ background:#F6EDE1; } .logo-thumb.dark{ background:var(--ink); }
  .logo-thumb img{ width:30px;height:30px; object-fit:cover; border-radius:50%; }
  .logo-caption{ font-size:11px; color:var(--ink-soft); text-align:center; margin-top:4px; }
  .logo-item{ text-align:center; }

  .chip-row{ display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; }
  .chip{ background:var(--amber-tint-strong); color:var(--amber-dark); font-size:11.5px; font-weight:600; padding:6px 12px; border-radius:100px; border:1px solid #F3E3B8; outline:none; }
  .chip[contenteditable]:focus{ background:#fff; border-color:var(--amber); color:var(--ink); }
  .chip.goal-sel{ background:var(--ink); color:var(--amber); border-color:var(--ink); }
  .chip.add{ cursor:pointer; background:#fff; color:var(--ink-soft); border-style:dashed; }
  .chip.goal{ cursor:pointer; }

  .summary-grid{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
  .summary-card{ border:1px solid var(--border); border-radius:12px; padding:14px 15px; }
  .summary-card h5{ margin:0 0 9px; font-size:11px; text-transform:uppercase; letter-spacing:.05em; color:var(--ink-soft); font-family:'Inter',sans-serif; font-weight:700; }
  .summary-swatches{ display:flex; gap:5px; margin-bottom:8px; }
  .summary-swatches i{ width:20px;height:20px;border-radius:6px; display:inline-block; border:1px solid rgba(0,0,0,.08); }
  .summary-line{ font-size:12px; color:var(--ink); margin:3px 0; }
  .summary-line span{ color:var(--ink-soft); }
  .summary-card .edit-link{ margin-top:8px; display:inline-block; }

  .build-promise{ border:1px solid var(--border); border-radius:12px; padding:6px 16px; margin-bottom:20px; }
  .promise{ display:flex; gap:11px; padding:11px 0; align-items:flex-start; }
  .promise + .promise{ border-top:1px solid var(--border); }
  .promise-ico{ width:22px;height:22px;border-radius:6px; background:var(--green-bg); color:var(--green); display:flex; align-items:center; justify-content:center; font-size:12px; flex-shrink:0; margin-top:1px; }
  .promise-txt{ font-size:12.5px; } .promise-txt b{ font-weight:600; }
  .promise-txt span{ display:block; color:var(--ink-soft); font-size:11.5px; margin-top:1px; }

  .confirm-box{ display:flex; gap:11px; align-items:flex-start; padding:14px 16px; background:var(--amber-tint-strong); border:1px solid #F3E3B8; border-radius:12px; cursor:pointer; }
  .confirm-box input{ margin-top:2px; width:16px; height:16px; accent-color:var(--amber-dark); flex-shrink:0; }
  .confirm-box label{ font-size:12.5px; line-height:1.5; cursor:pointer; }
  .confirm-box b{ font-weight:600; }

  .center{ text-align:center; }
  .build-head h2{ font-size:22px; margin:2px 0 6px; }
  .team-list{ margin:22px 0 6px; text-align:left; }
  .team-row{ display:flex; gap:13px; align-items:flex-start; padding:14px 0; }
  .team-row + .team-row{ border-top:1px solid var(--border); }
  .team-ico{ width:38px;height:38px;border-radius:10px; flex-shrink:0; display:flex;align-items:center;justify-content:center; font-size:18px; background:var(--bg); border:1px solid var(--border); }
  .team-main{ flex:1; }
  .team-role{ font-size:13px; font-weight:700; font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:2px; }
  .team-task{ font-size:12px; color:var(--ink-soft); }
  .team-status{ flex-shrink:0; display:flex; align-items:center; gap:6px; font-size:11.5px; font-weight:600; color:var(--ink-soft); }
  .spinner{ width:14px;height:14px;border-radius:50%; border:2px solid var(--border); border-top-color:var(--amber); animation:spin .8s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg); } }
  .team-row.done .team-status{ color:var(--green); }
  .team-row.done .team-ico{ background:var(--green-bg); border-color:#CFE9D8; }
  .team-row.waiting{ opacity:.5; }
  .check{ color:var(--green); font-weight:700; }

  .done-icon{ width:58px; height:58px; border-radius:50%; background:var(--green-bg); color:var(--green); display:flex; align-items:center; justify-content:center; font-size:28px; margin:0 auto 16px; }
  .saved-note{ display:inline-flex; align-items:center; gap:7px; margin:16px auto 6px; font-size:12px; color:var(--violet); background:var(--violet-bg); padding:8px 14px; border-radius:100px; }
  .done-actions{ display:flex; gap:10px; justify-content:center; margin-top:22px; }

  .step-panel{ display:none; } .step-panel.active{ display:block; }
</style>
</head>
<body data-mode="import">

  <div class="topbar">
    <div class="brand">
      <div class="brand-mark"><img src="/logo.png" alt="2Labs" width="30" height="30" /></div>
      <div class="brand-name">2Labs Sites</div>
    </div>
    <div style="display:flex; align-items:center; gap:14px;">
      <div class="org-pill"><div class="org-avatar" id="orgAvatar">2L</div> <span id="orgPillName">New site</span></div>
      <a class="close-x" href="/dashboard" title="Cancel">✕</a>
    </div>
  </div>

  <div class="wrap">
    <div class="stepper" id="stepper">
      <div class="step grow" data-step="1"><div class="step-dot">1</div><div class="step-label">Start</div><div class="step-line"></div></div>
      <div class="step grow" data-step="2"><div class="step-dot">2</div><div class="step-label">Brand</div><div class="step-line"></div></div>
      <div class="step grow" data-step="3"><div class="step-dot">3</div><div class="step-label">Content</div><div class="step-line"></div></div>
      <div class="step grow" data-step="4"><div class="step-dot">4</div><div class="step-label">Review</div><div class="step-line"></div></div>
      <div class="step" data-step="5"><div class="step-dot">5</div><div class="step-label">Build</div></div>
    </div>

    <div class="card wide">
      <!-- STEP 1 : START -->
      <div class="step-panel active" data-panel="1">
        <div class="eyebrow">Step 1 of 5</div>
        <h2>Let's create your new site</h2>
        <p class="sub">Bring an existing site over, describe the site you want in plain language, or start from a blank canvas.</p>
        <div class="choice-grid three">
          <div class="choice" id="choiceImport" onclick="setMode('import')">
            <div class="choice-ico">🌐</div>
            <h4>Import an existing site</h4>
            <p>We'll pull in your pages, brand &amp; content — then redesign and rewrite it.</p>
          </div>
          <div class="choice selected" id="choiceDescribe" onclick="setMode('describe')">
            <div class="choice-tag">Recommended</div>
            <div class="choice-ico">✍️</div>
            <h4>Describe your site</h4>
            <p>Tell us what it's for in plain language — we'll research, plan &amp; build it.</p>
          </div>
          <div class="choice" id="choiceBlank" onclick="setMode('blank')">
            <div class="choice-ico">✨</div>
            <h4>Start from blank</h4>
            <p>No site yet? We'll build from best practices as you fill in the details.</p>
          </div>
        </div>

        <div class="import-panel hidden" id="importPanel">
          <div class="import-visual"><div class="old-site"></div><div class="arrow">→</div><div class="new-site"></div></div>
          <div class="field" style="margin-bottom:0;">
            <label>Current website URL</label>
            <div class="url-row">
              <input type="text" id="urlInput" placeholder="e.g. riversideyouth.ca" />
              <button class="btn btn-primary" onclick="goTo(2)">Import &amp; continue →</button>
            </div>
            <div class="field-hint">We'll scan your site to extract brand, pages, and content.</div>
          </div>
        </div>

        <div class="import-panel" id="describePanel">
          <div class="field">
            <label>Describe the site you want</label>
            <textarea id="descInput" style="min-height:120px;" placeholder="Tell us what the site is for, who it's for, and any key details — dates, prices, locations, what you offer. e.g. “A website for a trail running race. Distances 10K, 25K, 50K; race day Sept 20 in Canmore; early-bird pricing until July.”"></textarea>
          </div>
          <div class="field">
            <label>Sites you like <span style="color:var(--ink-soft);font-weight:400;">(optional)</span></label>
            <div id="refRows"></div>
            <button type="button" class="btn btn-ghost" id="addRefBtn" style="padding:8px 14px;font-size:12.5px;">+ Add a reference</button>
            <div class="field-hint">We study their design &amp; structure patterns only — never their content or assets.</div>
          </div>
          <div class="field" style="margin-bottom:14px;">
            <label>Style notes <span style="color:var(--ink-soft);font-weight:400;">(optional)</span></label>
            <input type="text" id="styleInput" placeholder="e.g. modern and minimal · warm and community-feeling · bold and energetic" />
          </div>
          <button class="btn btn-primary" id="describeBtn" onclick="generateBrief()">Generate my brief →</button>
        </div>

        <div class="import-panel hidden" id="blankPanel">
          <p style="margin:0 0 14px; font-size:13px; color:var(--ink-soft); line-height:1.5;">No problem — you'll tell us your organization's mission, what you offer, and your main goal on the next steps, and our AI brand designer will propose a starting look you can shape.</p>
          <button class="btn btn-primary" onclick="goTo(2)">Start from blank →</button>
        </div>
      </div>

      <!-- STEP 1.5 : REFINE (describe path only) -->
      <div class="step-panel" data-panel="refine">
        <div class="eyebrow">Let's get the details right</div>
        <h2 id="refineTitle">Here's what I understood</h2>
        <div class="ai-callout">
