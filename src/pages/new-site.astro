      <!-- STEP 3 : CONTENT -->
      <div class="step-panel" data-panel="3">
        <div class="eyebrow">Step 3 of 5</div>
        <h2 class="if-import" style="display:none;">About your organization</h2>
        <h2 class="if-blank" style="display:none;">Tell us about your organization</h2>
        <p class="sub if-import" style="display:none;">We drafted this from your existing site — adjust anything so it sounds like you.</p>
        <p class="sub if-blank" style="display:none;">This shapes every page we build, so be as specific as you can. Fields marked <span class="req">*</span> are required.</p>
        <div class="field"><label>Organization name <span class="req if-blank" style="display:none;">*</span></label><input type="text" id="orgName" /></div>
        <div class="field"><label>Mission statement <span class="req if-blank" style="display:none;">*</span> <span class="ai-badge if-import" style="display:none;">◈ Drafted from your site</span></label><textarea id="mission"></textarea></div>
        <div class="field"><label>What you offer <span class="req if-blank" style="display:none;">*</span></label><div class="chip-row" id="offerRow"></div><div class="field-hint if-blank" style="display:none;">Add each program or service — we'll build a page or section for each.</div></div>
        <div class="field"><label>Main goal for site visitors <span class="req if-blank" style="display:none;">*</span></label><div class="field-hint" style="margin-top:0; margin-bottom:4px;">This becomes the primary call-to-action across your site.</div><div class="chip-row" id="goalRow"></div></div>
      </div>

      <!-- STEP 4 : REVIEW -->
      <div class="step-panel" data-panel="4">
        <div class="eyebrow">Step 4 of 5</div>
        <h2>Ready to build your site?</h2>
        <p class="sub">Here's everything we'll use. When you generate, our senior design &amp; development team builds a complete, world-class site — this takes a few minutes.</p>
        <div class="summary-grid">
          <div class="summary-card">
            <h5>Brand</h5>
            <div class="summary-swatches" id="summarySwatches"></div>
            <div class="summary-line" id="summaryFonts"><span>Fonts:</span> Plus Jakarta Sans · Inter</div>
            <div class="summary-line"><span>Logo:</span> light &amp; dark ready</div>
            <span class="edit-link" onclick="goTo(2)">Edit brand</span>
          </div>
          <div class="summary-card">
            <h5>Content</h5>
            <div class="summary-line" id="summaryOrg"><span>Org:</span> —</div>
            <div class="summary-line" id="summaryOffer"><span>Offers:</span> 0</div>
            <div class="summary-line" id="summaryGoal"><span>Goal:</span> (not set)</div>
