---
// dashboard.astro — the builder home: the signed-in user's sites. Pick a site
// to edit, open its settings, or create a new one. Data from /api/list-sites.
import brand from '../../site-config/brand.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<script is:inline>if(!localStorage.getItem('2labs_sites_token'))location.replace('/login');</script>
<title>Your sites — 2Labs Sites</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style is:global>
  :root{ --amber:#F59F0A; --amber-dark:#D9870A; --amber-tint-strong:#FFFBEB; --ink:#1F242E; --ink-soft:#676F7E; --bg:#F8F7F6; --surface:#FFFFFF; --border:#E5E0DC; --green:#2F8558; --green-bg:#EAF6EF; --radius:14px; --shadow:0 1px 2px rgba(31,36,46,0.04), 0 10px 28px rgba(31,36,46,0.06); }
  *{box-sizing:border-box;}
  body{ margin:0; background:var(--bg); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; }
  h1,h2,h3{ font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.01em; }
  a{ color:inherit; }
  .app{ max-width:1080px; margin:0 auto; padding:0 24px 64px; }
  .topbar{ display:flex; align-items:center; justify-content:space-between; padding:20px 0; margin-bottom:30px; border-bottom:1px solid var(--border); }
  .brand{ display:flex; align-items:center; gap:10px; }
  .brand-mark{ width:34px;height:34px;border-radius:50%; overflow:hidden; flex-shrink:0; }
  .brand-mark img{ width:100%;height:100%; object-fit:cover; display:block; }
  .brand-name{ font-weight:800; font-size:16px; } .brand-name span{ color:var(--amber-dark); }
  .topbar-right{ display:flex; align-items:center; gap:12px; }
  .userpill{ display:flex; align-items:center; gap:8px; background:var(--surface); border:1px solid var(--border); padding:6px 14px 6px 6px; border-radius:100px; box-shadow:var(--shadow); font-size:13px; }
  .avatar{ width:26px;height:26px;border-radius:50%; background:var(--amber); display:flex;align-items:center;justify-content:center; color:var(--ink);font-size:11px;font-weight:700; }
  .icon-btn{ border:1px solid var(--border); background:var(--surface); border-radius:9px; padding:8px 14px; font-size:13px; font-weight:600; color:var(--ink); cursor:pointer; }
  .icon-btn:hover{ border-color:var(--ink-soft); }
  .credits{ display:flex; align-items:center; gap:8px; background:var(--surface); border:1px solid var(--border); border-radius:100px; padding:7px 14px; box-shadow:var(--shadow); }
  .credits-bar{ width:56px; height:6px; border-radius:100px; background:#EDE8E4; overflow:hidden; }
  .credits-fill{ display:block; height:100%; width:0%; border-radius:100px; background:var(--green); transition:width .4s ease, background .3s; }
  .credits-fill.warn{ background:var(--amber-dark); } .credits-fill.full{ background:#C0392B; }
  .credits-label{ font-size:12px; font-weight:600; color:var(--ink-soft); white-space:nowrap; }
  .head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; }
  .head h1{ font-size:24px; margin:0; }
  .btn-primary{ background:var(--amber); color:var(--ink); border:none; border-radius:10px; padding:11px 18px; font-weight:600; font-size:14px; cursor:pointer; }
  .btn-primary:hover{ background:var(--amber-dark); }

  .grid{ display:grid; grid-template-columns:repeat(auto-fit, minmax(440px,1fr)); gap:22px; }
  @media (max-width:520px){ .grid{ grid-template-columns:1fr; } }
  .card{ background:var(--surface); border:1px solid var(--border); border-radius:18px; box-shadow:var(--shadow); overflow:hidden; display:flex; flex-direction:column; }
  .card-body{ padding:26px 28px 22px; flex:1; }
  .card-top{ display:flex; align-items:flex-start; justify-content:space-between; gap:14px; }
  .card-name{ font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:22px; line-height:1.2; }
  .card-domain{ font-size:14px; color:var(--ink-soft); margin-top:5px; }
  .card-domain a{ color:var(--amber-dark); text-decoration:none; }
  .pill{ display:inline-flex; align-items:center; gap:6px; font-size:11px; font-weight:600; padding:5px 11px; border-radius:100px; white-space:nowrap; flex-shrink:0; }
  .pill-green{ background:var(--green-bg); color:var(--green); }
  .pill-amber{ background:var(--amber-tint-strong); color:var(--amber-dark); }
  .pill .dot{ width:6px;height:6px;border-radius:50%; background:currentColor; }

  .metrics{ display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-top:22px; }
  .metric{ background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:14px 10px; text-align:center; }
  .metric-val{ font-family:'Plus Jakarta Sans',sans-serif; font-weight:800; font-size:24px; line-height:1; color:var(--ink-soft); }
  .metric-val.good{ color:var(--green); } .metric-val.avg{ color:var(--amber-dark); } .metric-val.poor{ color:#C0392B; }
  .metric-label{ font-size:11px; font-weight:600; color:var(--ink-soft); margin-top:7px; text-transform:uppercase; letter-spacing:0.03em; }
  .metric-sub{ font-size:10px; color:var(--ink-soft); margin-top:2px; opacity:.8; }
  .metric-dot{ display:inline-block; width:8px;height:8px;border-radius:50%; background:#D9D3CD; animation:blink 1s infinite alternate; }
  @keyframes blink{ to{ opacity:.35; } }

  .card-actions{ display:grid; grid-template-columns:repeat(3,1fr); gap:10px; padding:16px 28px 22px; }
  .card-actions a{ display:flex; align-items:center; justify-content:center; gap:6px; border-radius:11px; padding:12px 10px; font-size:13.5px; font-weight:600; text-decoration:none; cursor:pointer; border:1px solid var(--border); background:var(--surface); color:var(--ink); }
  .card-actions a:hover{ border-color:var(--ink-soft); }
  .card-actions a.primary{ background:var(--amber); border-color:var(--amber); }
  .card-actions a.primary:hover{ background:var(--amber-dark); }
  .card-actions a[aria-disabled="true"]{ opacity:.45; pointer-events:none; }
  .empty, .loading{ color:var(--ink-soft); font-size:14px; padding:40px 0; text-align:center; }

  .modal-overlay{ position:fixed; inset:0; background:rgba(31,36,46,0.45); display:none; align-items:center; justify-content:center; padding:24px; z-index:60; }
  .modal-overlay.open{ display:flex; }
  .modal{ width:100%; max-width:420px; background:var(--surface); border-radius:16px; box-shadow:0 24px 60px rgba(15,23,42,0.28); padding:24px; }
  .modal h3{ margin:0 0 4px; font-size:18px; }
  .modal p{ margin:0 0 18px; font-size:13px; color:var(--ink-soft); }
  .field{ margin-bottom:14px; }
  .field label{ display:block; font-size:12px; font-weight:600; color:var(--ink-soft); margin-bottom:6px; }
  .field input{ width:100%; border:1px solid var(--border); border-radius:10px; padding:11px 13px; font-family:'Inter',sans-serif; font-size:14px; background:var(--bg); color:var(--ink); }
  .field input:focus{ outline:none; border-color:var(--amber); }
  .modal-actions{ display:flex; gap:10px; justify-content:flex-end; margin-top:6px; }
  .modal-actions .cancel{ background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:10px 16px; font-weight:600; font-size:13px; cursor:pointer; }
  footer{ text-align:center; margin-top:36px; color:var(--ink-soft); font-size:12px; }
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="brand">
      <div class="brand-mark"><img src="/logo.png" alt="2Labs" width="34" height="34" /></div>
      <div class="brand-name">2Labs<span>Sites</span></div>
    </div>
    <div class="topbar-right">
      <div class="credits" id="credits" title="AI edits used this month">
        <div class="credits-bar"><span class="credits-fill" id="creditsFill"></span></div>
        <span class="credits-label" id="creditsLabel">— / —</span>
      </div>
      <div class="userpill"><span class="avatar" id="userAvatar">·</span> <span id="userEmail">…</span></div>
      <button class="icon-btn" id="signOut">Sign out</button>
    </div>
  </div>

  <div class="head">
    <h1>Your sites</h1>
    <button class="btn-primary" id="newSiteBtn">+ New site</button>
  </div>

  <div id="sitesGrid" class="grid"><div class="loading">Loading your sites…</div></div>

  <footer>2Labs Sites — proudly Canadian-owned 🍁</footer>
</div>

<div class="modal-overlay" id="newSiteModal">
  <div class="modal">
    <h3>New site</h3>
    <p>Give it a name and domain. You'll connect its GitHub repo in Settings.</p>
    <div class="field"><label for="nsName">Site name</label><input id="nsName" placeholder="Acme Nonprofit" /></div>
    <div class="field"><label for="nsDomain">Domain</label><input id="nsDomain" placeholder="acme.org" /></div>
    <div class="modal-actions">
      <button class="cancel" id="nsCancel">Cancel</button>
      <button class="btn-primary" id="nsCreate">Create site</button>
    </div>
  </div>
</div>

<script>
  const TOKEN_KEY = '2labs_sites_token';
  const authToken = () => localStorage.getItem(TOKEN_KEY);
  const signOut = () => { localStorage.removeItem(TOKEN_KEY); location.replace('/login'); };
  document.getElementById('signOut').addEventListener('click', signOut);

  function apiFetch(path, opts = {}) {
    return fetch(path, { ...opts, headers: { 'Content-Type': 'application/json', 'x-2labs-session': authToken() || '', 'Authorization': 'Bearer ' + (authToken() || ''), ...(opts.headers || {}) } });
  }

  const grid = document.getElementById('sitesGrid');

  function statusPill(site) {
    return site.editable
      ? '<span class="pill pill-green"><span class="dot"></span> Ready to edit</span>'
      : '<span class="pill pill-amber"><span class="dot"></span> Connect repo</span>';
  }

  const band = (v) => v == null ? '' : (v >= 90 ? 'good' : (v >= 50 ? 'avg' : 'poor'));

  function metricTile(key, label) {
    return '<div class="metric" data-metric="' + key + '">' +
      '<div class="metric-val"><span class="metric-dot"></span></div>' +
      '<div class="metric-label">' + label + '</div>' +
    '</div>';
  }

  function renderSites(sites) {
    if (!sites.length) { grid.innerHTML = '<div class="empty">No sites yet — create your first one.</div>'; return; }
    grid.innerHTML = '';
    for (const s of sites) {
      const card = document.createElement('div');
      card.className = 'card';
      const q = encodeURIComponent(s.slug);
      const url = s.domain ? 'https://' + String(s.domain).replace(/^https?:\/\//, '') : null;
      card.innerHTML =
        '<div class="card-body">' +
          '<div class="card-top">' +
            '<div><div class="card-name"></div><div class="card-domain"></div></div>' +
            statusPill(s) +
          '</div>' +
          '<div class="metrics">' +
            metricTile('performance', 'Performance') +
            metricTile('accessibility', 'Accessibility') +
            metricTile('seo', 'SEO') +
            metricTile('views', 'Page views') +
          '</div>' +
        '</div>' +
        '<div class="card-actions">' +
          '<a class="primary" href="/site?site=' + q + '">📊 Site Analytics</a>' +
          '<a ' + (s.editable ? '' : 'aria-disabled="true"') + ' href="/editor?site=' + q + '">✎ Open Editor</a>' +
          '<a href="/site-settings?site=' + q + '">⚙ Site Settings</a>' +
        '</div>';
      card.querySelector('.card-name').textContent = s.name;
      const dom = card.querySelector('.card-domain');
      if (url) { const a = document.createElement('a'); a.href = url; a.target = '_blank'; a.rel = 'noopener'; a.textContent = s.domain; dom.appendChild(a); }
      else { dom.textContent = '(no domain set)'; }
      grid.appendChild(card);
      loadCardMetrics(card, s);
    }
  }

  function setMetric(card, key, value, sub) {
    const tile = card.querySelector('.metric[data-metric="' + key + '"] .metric-val');
    if (!tile) return;
    tile.classList.remove('good', 'avg', 'poor');
    if (value == null) { tile.textContent = '—'; }
    else { tile.textContent = value; const b = band(typeof value === 'number' ? value : null); if (b) tile.classList.add(b); }
    const t = card.querySelector('.metric[data-metric="' + key + '"]');
    let subEl = t.querySelector('.metric-sub');
    if (sub) { if (!subEl) { subEl = document.createElement('div'); subEl.className = 'metric-sub'; t.appendChild(subEl); } subEl.textContent = sub; }
    else if (subEl) subEl.remove();
  }

  // Page views need GA4 (not wired yet) — always show a "connect" hint for now.
  async function loadCardMetrics(card, s) {
    setMetric(card, 'views', null, 'Connect GA4');
    if (!s.domain) {
      ['performance', 'accessibility', 'seo'].forEach((k) => setMetric(card, k, null, 'Not published'));
      return;
    }
    try {
      const res = await apiFetch('/api/site-metrics?site=' + encodeURIComponent(s.slug));
      const data = await res.json().catch(() => ({}));
      if (data.status === 'ok' && data.scores) {
        setMetric(card, 'performance', data.scores.performance);
        setMetric(card, 'accessibility', data.scores.accessibility);
        setMetric(card, 'seo', data.scores.seo);
      } else {
        const hint = data.status === 'not_published' ? 'Not published' : 'Unavailable';
        ['performance', 'accessibility', 'seo'].forEach((k) => setMetric(card, k, null, hint));
      }
    } catch (e) {
      ['performance', 'accessibility', 'seo'].forEach((k) => setMetric(card, k, null, ''));
    }
  }

  async function loadSites() {
    try {
      const res = await apiFetch('/api/list-sites');
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) { signOut(); return; }
      if (data.status === 'ok') renderSites(data.sites || []);
      else grid.innerHTML = '<div class="empty">Could not load your sites.</div>';
    } catch (e) { grid.innerHTML = '<div class="empty">Could not reach the service.</div>'; }
  }

  // New-site modal
  const modal = document.getElementById('newSiteModal');
  document.getElementById('newSiteBtn').addEventListener('click', () => { location.href = '/new-site'; });
  document.getElementById('nsCancel').addEventListener('click', () => modal.classList.remove('open'));
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('open'); });
  document.getElementById('nsCreate').addEventListener('click', async () => {
    const name = document.getElementById('nsName').value.trim();
    const domain = document.getElementById('nsDomain').value.trim();
    if (!name) return;
    const btn = document.getElementById('nsCreate'); btn.disabled = true; btn.textContent = 'Creating…';
    try {
      const res = await apiFetch('/api/save-site', { method: 'POST', body: JSON.stringify({ name, domain }) });
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) { signOut(); return; }
      if (data.status === 'ok' && data.site) { location.href = '/site-settings?site=' + encodeURIComponent(data.site.slug); return; }
    } catch (e) {}
    btn.disabled = false; btn.textContent = 'Create site';
  });

  // AI credit meter (1 edit = 1 credit), account-wide for the month.
  async function loadCredits() {
    try {
      const res = await apiFetch('/api/usage');
      if (!res.ok) return;
      const u = await res.json();
      const limit = u.limit || 0, used = u.used || 0;
      const pct = limit ? Math.min(100, Math.round((used / limit) * 100)) : 0;
      const fill = document.getElementById('creditsFill');
      fill.style.width = pct + '%';
      fill.classList.toggle('warn', pct >= 80 && pct < 100);
      fill.classList.toggle('full', pct >= 100);
      document.getElementById('creditsLabel').textContent = `${used} / ${limit} edits`;
      const reset = u.resetsOn ? new Date(u.resetsOn).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) : '';
      document.getElementById('credits').title = `${u.remaining} AI edits left this month${reset ? ' · resets ' + reset : ''}`;
    } catch (e) { /* best-effort */ }
  }

  // User pill from the session (best-effort: token is opaque, so show a generic identity)
  document.getElementById('userEmail').textContent = 'Signed in';
  document.getElementById('userAvatar').textContent = '2L';

  loadSites();
  loadCredits();
</script>
</body>
</html>
