<script>
  const TOKEN_KEY = '2labs_sites_token';
  const authToken = () => localStorage.getItem(TOKEN_KEY);
  const signOut = () => { localStorage.removeItem(TOKEN_KEY); location.replace('/login'); };
  function apiFetch(path, opts = {}) {
    return fetch(path, { ...opts, headers: { 'Content-Type': 'application/json', 'x-2labs-session': authToken() || '', 'Authorization': 'Bearer ' + (authToken() || ''), ...(opts.headers || {}) } });
  }
  const slug = new URLSearchParams(location.search).get('site');
  const $ = (id) => document.getElementById(id);
  let currentBrief = null; // the site's Wizard Brief (holds the brand system)

  const HEAD_FONTS = ['Plus Jakarta Sans', 'Poppins', 'Montserrat', 'Sora', 'Space Grotesk', 'Fraunces', 'DM Serif Display'];
  const BODY_FONTS = ['Inter', 'Open Sans', 'Source Sans 3', 'Work Sans', 'Nunito Sans', 'Lato'];

  // ---- left-nav section switching ----
  document.querySelectorAll('.nav-item').forEach((item) => {
    item.addEventListener('click', () => {
      const target = item.dataset.target;
      document.querySelectorAll('.nav-item').forEach((n) => n.classList.toggle('active', n === item));
      document.querySelectorAll('.section').forEach((s) => s.classList.toggle('active', s.dataset.section === target));
      $('content') && $('content').scrollTo && $('content').scrollTo(0, 0);
    });
  });

  // ---- editable swatch bound to a color object (mutated in place) ----
  function makeSwatch(c, rec) {
    const wrap = document.createElement('div'); wrap.className = 'swatch' + (rec ? ' rec' : '');
    const color = document.createElement('input'); color.type = 'color'; color.className = 'swatch-color'; color.value = c.hex || '#000000';
    const hex = document.createElement('input'); hex.type = 'text'; hex.className = 'swatch-hex'; hex.value = c.hex || ''; hex.maxLength = 7;
    const name = document.createElement('div'); name.className = 'swatch-name'; name.textContent = c.name || '';
    color.addEventListener('input', () => { hex.value = color.value.toUpperCase(); c.hex = color.value.toUpperCase(); syncTokenDemo(); });
    hex.addEventListener('change', () => { if (/^#[0-9a-fA-F]{6}$/.test(hex.value)) { color.value = hex.value; c.hex = hex.value.toUpperCase(); syncTokenDemo(); } });
    wrap.append(color, hex, name); return wrap;
  }

  function fillSelect(sel, options, current) {
    sel.innerHTML = '';
    const list = options.includes(current) || !current ? options : [current, ...options];
    list.forEach((f) => { const o = document.createElement('option'); o.value = f; o.textContent = f; if (f === current) o.selected = true; sel.appendChild(o); });
  }

  // Update the primary-button + radius demos from the live brand.
  function syncTokenDemo() {
    const brand = currentBrief && currentBrief.brand; if (!brand) return;
    const core = brand.colors && brand.colors.core;
    const radius = (brand.tokens && brand.tokens.radius != null) ? brand.tokens.radius : 14;
    const demo = $('btnTokenDemo');
    if (core && core[0] && demo) {
      const primary = core[0].hex || '#F59F0A';
      demo.style.background = primary; demo.style.color = bestTextOn(primary); demo.style.borderRadius = radius + 'px';
      $('btnTokenVal').textContent = 'bg ' + (core[0].name || 'primary').toLowerCase() + ' · ' + (bestTextOn(primary) === '#FFFFFF' ? 'light' : 'dark') + ' text';
    }
    if ($('radiusDemo')) $('radiusDemo').style.borderRadius = radius + 'px';
  }

  const clampInt = (v, def, min, max) => { const n = Math.round(Number(v)); return Number.isFinite(n) ? Math.max(min, Math.min(max, n)) : def; };
  const SCALE_KEYS = [['h1', 'H1'], ['h2', 'H2'], ['h3', 'H3'], ['body', 'Body'], ['small', 'Small']];
  const SCALE_BOUNDS = { h1: [20, 96], h2: [16, 72], h3: [14, 48], body: [12, 22], small: [10, 18] };
  const SCALE_DEF = { h1: 32, h2: 24, h3: 19, body: 16, small: 13 };

  function renderScale(t) {
    const sc = t.scale || (t.scale = { ...SCALE_DEF });
    for (const k of Object.keys(SCALE_DEF)) if (sc[k] == null) sc[k] = SCALE_DEF[k];
    const grid = $('scaleGrid'); grid.innerHTML = '';
    SCALE_KEYS.forEach(([key, label]) => {
      const cell = document.createElement('div'); cell.className = 'scale-cell';
      const lab = document.createElement('label'); lab.textContent = label;
      const inp = document.createElement('input'); inp.type = 'number'; inp.value = sc[key]; inp.min = SCALE_BOUNDS[key][0]; inp.max = SCALE_BOUNDS[key][1];
      inp.oninput = () => { sc[key] = clampInt(inp.value, SCALE_DEF[key], SCALE_BOUNDS[key][0], SCALE_BOUNDS[key][1]); };
      cell.append(lab, inp); grid.appendChild(cell);
    });
  }

  const SPACE_DEF = [4, 8, 12, 16, 24, 32];
  function renderSpacing(tk) {
    let sp = Array.isArray(tk.spacing) && tk.spacing.length === 6 ? tk.spacing : (tk.spacing = SPACE_DEF.slice());
    const grid = $('spaceGrid'); grid.innerHTML = '';
    sp.forEach((val, i) => {
      const cell = document.createElement('div'); cell.className = 'scale-cell';
      const lab = document.createElement('label'); lab.textContent = 'S' + (i + 1);
      const inp = document.createElement('input'); inp.type = 'number'; inp.value = val; inp.min = 0; inp.max = 160;
      inp.oninput = () => { sp[i] = clampInt(inp.value, SPACE_DEF[i], 0, 160); };
      cell.append(lab, inp); grid.appendChild(cell);
    });
  }

  function collectVoice() {
    const arr = [...document.querySelectorAll('#bgVoice .voice-tag [contenteditable]')].map((e) => e.textContent.trim()).filter(Boolean);
    currentBrief.brand.voice = arr;
    renderPreview();
  }
  function voiceChip(text) {
    const chip = document.createElement('span'); chip.className = 'voice-tag';
    const ed = document.createElement('span'); ed.contentEditable = 'true'; ed.textContent = text;
    ed.oninput = collectVoice;
    ed.onkeydown = (e) => { if (e.key === 'Enter') { e.preventDefault(); ed.blur(); } };
    const x = document.createElement('span'); x.className = 'vx'; x.textContent = '×'; x.title = 'Remove';
    x.onclick = () => { chip.remove(); collectVoice(); };
    chip.append(ed, x); return chip;
  }
  function renderVoice(brand) {
    const wrap = $('bgVoice'); wrap.innerHTML = '';
    (brand.voice || []).forEach((v) => wrap.appendChild(voiceChip(v)));
    const add = document.createElement('button'); add.type = 'button'; add.className = 'voice-add'; add.textContent = '+ Add';
    add.onclick = () => { const c = voiceChip('new'); wrap.insertBefore(c, add); const ed = c.querySelector('[contenteditable]'); ed.focus(); const r = document.createRange(); r.selectNodeContents(ed); const s = getSelection(); s.removeAllRanges(); s.addRange(r); collectVoice(); };
    wrap.appendChild(add);
  }

  function renderLogo(brand) {
    const url = brand.logo && brand.logo.url;
    const set = (boxId, wordId, wordColor) => {
      const box = $(boxId);
      if (url) { box.innerHTML = ''; const img = document.createElement('img'); img.src = url; img.alt = 'Logo'; box.appendChild(img); }
      else { box.innerHTML = '<span class="wordmark" id="' + wordId + '" style="color:' + wordColor + ';">' + initials($('fName').value) + '</span>'; }
    };
    set('logoLight', 'logoWordLight', 'var(--ink)');
    set('logoDark', 'logoWordDark', '#fff');
    $('logoWordmark').textContent = initials($('fName').value);
    if ($('logoStatus')) { $('logoStatus').style.display = brand.logo && brand.logo.name ? 'block' : 'none'; $('logoStatus').textContent = brand.logo && brand.logo.name ? '✓ ' + brand.logo.name + ' — saved on this brand' : ''; }
  }
  // Minimal luminance check to pick readable text on a swatch.
  function toRgb(hex) { const m = /^#?([0-9a-f]{6})$/i.exec(hex || ''); return m ? [0, 2, 4].map((i) => parseInt(m[1].slice(i, i + 2), 16)) : null; }
  function lum(hex) { const c = toRgb(hex); if (!c) return 0.5; const [r, g, b] = c.map((v) => v / 255); return 0.2126 * r + 0.7152 * g + 0.0722 * b; }
  function bestTextOn(hex) { return lum(hex) > 0.55 ? '#1F242E' : '#FFFFFF'; }
  function mix(a, b, t) { const x = toRgb(a), y = toRgb(b); if (!x || !y) return a; return '#' + x.map((v, i) => Math.round(v + (y[i] - v) * t).toString(16).padStart(2, '0')).join(''); }

  // Keep the preview's fonts loaded as the user switches families.
  function ensurePreviewFonts(heading, body) {
    let link = document.getElementById('pvFonts');
    if (!link) { link = document.createElement('link'); link.id = 'pvFonts'; link.rel = 'stylesheet'; document.head.appendChild(link); }
    const fam = (f) => encodeURIComponent(f) + ':wght@400;500;600;700;800';
    link.href = 'https://fonts.googleapis.com/css2?family=' + fam(heading) + '&family=' + fam(body) + '&display=swap';
  }

  // Live mini-site preview — mirrors tokensFromBrand's derivation (ink/paper by
  // luminance, contrast tokens) so what the user sees matches what ships.
  function renderPreview() {
    const brand = currentBrief && currentBrief.brand; if (!brand || !brand.colors) return;
    const el = $('brandPreview'); if (!el) return;
    const colors = brand.colors;
    const isHex = (h) => /^#[0-9a-f]{6}$/i.test(h || '');
    const neutral = (colors.neutral || []).filter((c) => isHex(c.hex));
    const ramp = neutral.length >= 2 ? neutral : [{ hex: '#1F242E' }, { hex: '#676F7E' }, { hex: '#E5E0DC' }, { hex: '#F7F8FA' }];
    const sorted = [...ramp].sort((a, b) => lum(a.hex) - lum(b.hex));
    const ink = sorted[0].hex, paper = sorted[sorted.length - 1].hex;
    const named = (n) => (neutral.find((c) => (c.name || '').toLowerCase().includes(n)) || {}).hex;
    const inkSoft = named('muted') || named('slate') || mix(ink, paper, 0.42);
    const border = named('line') || mix(ink, paper, 0.86);
    const core = colors.core || [];
    const primary = (isHex(core[0] && core[0].hex) && core[0].hex) || '#2F5DA8';
    const accent = (colors.accents && colors.accents[0] && colors.accents[0].hex) || primary;
    const t = brand.typography || {}; const sc = t.scale || SCALE_DEF;
    const tk = brand.tokens || {}; const radius = Math.min(tk.radius != null ? tk.radius : 14, 22);
    const heading = t.heading || 'Plus Jakarta Sans', body = t.body || 'Inter';
    const set = (k, v) => el.style.setProperty(k, v);
    set('--p-primary', primary); set('--p-primary-contrast', bestTextOn(primary));
    set('--p-accent', accent); set('--p-accent-contrast', bestTextOn(accent));
    set('--p-ink', ink); set('--p-ink-soft', inkSoft); set('--p-ink-contrast', bestTextOn(ink));
    set('--p-bg', paper); set('--p-surface', '#FFFFFF'); set('--p-border', border);
    set('--p-soft', mix(primary, '#FFFFFF', 0.88));
    set('--p-radius', radius + 'px');
    set('--p-fh', "'" + heading + "'"); set('--p-fb', "'" + body + "'");
    set('--p-h1', Math.max(18, Math.round((sc.h1 || 32) * 0.62)) + 'px');
    set('--p-h2', Math.max(13, Math.round((sc.h2 || 24) * 0.62)) + 'px');
    set('--p-body', Math.max(11, Math.round((sc.body || 16) * 0.8)) + 'px');
    ensurePreviewFonts(heading, body);
    // dynamic text
    const org = ($('fName').value || 'Your Brand').trim();
    const logo = brand.logo && brand.logo.url;
    $('mockLogo').innerHTML = logo ? '<img src="' + logo + '" alt="logo" />' : org;
    $('mockFootLogo').textContent = org;
    $('mockUrl').textContent = ($('fDomain').value || slug || 'yoursite.com').trim();
    if (brand.tagline) $('mockH1').textContent = brand.tagline;
    const cta = (currentBrief.content && currentBrief.content.primary_goal) || 'Get started';
    $('mockCtaTop').textContent = cta; $('mockCtaHero').textContent = cta;
    $('mockFootVoice').textContent = (brand.voice || []).join(' · ');
  }

  function renderBrand() {
    const brand = currentBrief && currentBrief.brand;
    const colors = brand && brand.colors;
    if (!colors) { $('brandEmpty').style.display = 'block'; $('brandBody').style.display = 'none'; return; }
    $('brandEmpty').style.display = 'none'; $('brandBody').style.display = 'block';
    $('brandOrigin').style.display = (currentBrief.createdFrom === 'onboarding' || currentBrief.mode) ? 'inline-flex' : 'none';
    const fill = (id, arr, rec) => { const row = $(id); row.innerHTML = ''; (arr || []).forEach((c) => row.appendChild(makeSwatch(c, rec))); };
    fill('bgCore', colors.core, false);
    fill('bgAccent', colors.accents, true);
    fill('bgSemantic', colors.semantic, false);
    fill('bgNeutral', colors.neutral, false);

    // brand basics
    $('fTagline').value = brand.tagline || '';
    $('fTagline').oninput = () => { brand.tagline = $('fTagline').value; };
    const content = currentBrief.content || (currentBrief.content = {});
    $('fCtaLabel').value = content.primary_goal || '';
    $('fCtaLabel').oninput = () => { content.primary_goal = $('fCtaLabel').value; };

    // typography (live — selects + scale inputs mutate the brief)
    const t = brand.typography || (brand.typography = {});
    $('headName').textContent = t.heading || 'Plus Jakarta Sans';
    $('bodyName').textContent = t.body || 'Inter';
    fillSelect($('headSelect'), HEAD_FONTS, t.heading || 'Plus Jakarta Sans');
    fillSelect($('bodySelect'), BODY_FONTS, t.body || 'Inter');
    $('headSelect').onchange = () => { t.heading = $('headSelect').value; $('headName').textContent = t.heading; };
    $('bodySelect').onchange = () => { t.body = $('bodySelect').value; $('bodyName').textContent = t.body; };
    renderScale(t);

    // layout & style (live radius + spacing)
    const tk = brand.tokens || (brand.tokens = {});
    if (tk.radius == null) tk.radius = 14;
    $('radiusInput').value = tk.radius;
    $('radiusInput').oninput = () => { tk.radius = clampInt($('radiusInput').value, 14, 0, 40); syncTokenDemo(); };
    renderSpacing(tk);

    // voice (live, editable)
    renderVoice(brand);

    // logo (live)
    renderLogo(brand);

    if (brand.a11y) { $('bgA11y').style.display = 'flex'; $('bgA11y').textContent = brand.a11y.passed ? '♿ All text/background pairings pass WCAG 2.2 AA contrast' : '⚠ Some pairings need adjustment for WCAG 2.2 AA'; }
    syncTokenDemo();
    renderPreview();
  }

  function initials(name) { return (name || '2Labs').split(/\s+/).slice(0, 2).map((w) => w[0]).join('').toUpperCase().slice(0, 2) || '2L'; }

  async function load() {
    if (!slug) { location.replace('/dashboard'); return; }
    try {
      const res = await apiFetch('/api/list-sites');
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) { signOut(); return; }
      const site = (data.sites || []).find((s) => s.slug === slug);
      if (!site) { location.replace('/dashboard'); return; }
      $('tbName').textContent = site.name || site.slug;
      $('fName').value = site.name || '';
      $('fDomain').value = site.domain || '';
      $('fDomainMirror').value = site.domain || '';
      $('fName').addEventListener('input', () => { $('tbName').textContent = $('fName').value || site.slug; });
      $('fDomain').addEventListener('input', () => { $('fDomainMirror').value = $('fDomain').value; });
      $('logoWordmark').textContent = initials(site.name);
      const gh = site.github || {};
      $('fOwner').value = gh.owner || '';
      $('fRepo').value = gh.repo || '';
      $('fBranch').value = gh.branch || 'main';
      currentBrief = site.brief || null;
      renderBrand();
    } catch (e) {}
  }

  const flashSaved = () => { const s = $('saved'); s.classList.add('show'); setTimeout(() => s.classList.remove('show'), 1800); };

  // Apply to Site — confirm first (brand styles regenerate across all pages),
  // then persist. save-site rebuilds tokens.css with the same contrast-safe
  // rules used during generation, so edits roll out site-wide.
  const am = $('applyModal');
  $('saveBtn').addEventListener('click', () => {
    if (currentBrief && currentBrief.brand && currentBrief.brand.colors) { am.classList.add('open'); }
    else doApply();
  });
  $('amCancel').addEventListener('click', () => am.classList.remove('open'));
  am.addEventListener('click', (e) => { if (e.target === am) am.classList.remove('open'); });
  $('amApply').addEventListener('click', () => { am.classList.remove('open'); doApply(); });

  async function doApply() {
    const btn = $('saveBtn'); btn.disabled = true; btn.textContent = 'Applying…';
    try {
      const body = {
        slug,
        name: $('fName').value.trim(),
        domain: $('fDomain').value.trim(),
        ...(currentBrief ? { brief: currentBrief } : {}),
      };
      const res = await apiFetch('/api/save-site', { method: 'POST', body: JSON.stringify(body) });
      if (res.status === 401) { signOut(); return; }
      if (res.ok) flashSaved();
    } catch (e) {}
    btn.disabled = false; btn.textContent = 'Apply to Site';
  }

  $('discardBtn').addEventListener('click', () => location.reload());

  // Logo upload — stores the image as an asset and attaches its URL to the brand.
  $('logoUploadBtn').addEventListener('click', () => { if (currentBrief && currentBrief.brand) $('logoFile').click(); });
  $('logoFile').addEventListener('change', async () => {
    const file = $('logoFile').files[0]; if (!file) return;
    const st = $('logoStatus'); st.style.display = 'block';
    if (file.size > 8 * 1024 * 1024) { st.textContent = 'That file is larger than 8 MB.'; return; }
    st.textContent = 'Uploading…';
    try {
      const dataBase64 = await new Promise((res, rej) => { const r = new FileReader(); r.onload = () => res(String(r.result).split(',')[1]); r.onerror = rej; r.readAsDataURL(file); });
      const up = await apiFetch('/api/upload-asset', { method: 'POST', body: JSON.stringify({ name: file.name, type: file.type, dataBase64 }) });
      const data = await up.json().catch(() => ({}));
      if (up.status === 401) { signOut(); return; }
      if (data.status === 'ok' && data.asset && data.asset.url) {
        currentBrief.brand.logo = { url: data.asset.url, name: data.asset.name, id: data.asset.id };
        renderLogo(currentBrief.brand); renderPreview();
        st.textContent = '✓ ' + data.asset.name + ' uploaded — Apply to Site to roll it out across every page.';
      } else { st.textContent = data.error || 'Upload failed.'; }
    } catch (e) { st.textContent = 'Upload failed.'; }
    $('logoFile').value = '';
  });

