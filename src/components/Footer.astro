---
// Footer.astro — STRUCTURAL FILE, same edit policy as Header.astro
interface Props { orgName: string; }
const { orgName } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <span>{orgName} &copy; {year}</span>
    <span class="proud">Proudly Canadian-owned 🍁</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 28px 24px;
    margin-top: 48px;
  }
  .footer-inner {
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12.5px;
    color: var(--ink-soft);
  }
  .proud { font-weight: 600; color: var(--ink); }
  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
