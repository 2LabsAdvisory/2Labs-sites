---
// Default starter home for the base skeleton. The seed overlays this with a
// per-site version built from the Wizard Brief; this default renders if a site
// is opened before it's seeded.
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="A brand-new site, ready to build." orgName="Your Site">
  <section style="max-width:760px;margin:0 auto;padding:80px 24px;text-align:center;">
    <h1 style="font-size:44px;line-height:1.1;">Your new site starts here</h1>
    <p style="font-size:18px;color:var(--ink-soft);line-height:1.6;margin:16px 0 28px;">Describe a change in the editor and watch it appear. Add pages, write content, and shape the design — all in plain language.</p>
    <a href="/contact" style="display:inline-block;background:var(--primary);color:var(--on-primary);font-weight:600;padding:13px 24px;border-radius:10px;text-decoration:none;">Get started</a>
  </section>
</BaseLayout>
