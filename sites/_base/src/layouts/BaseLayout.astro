---
// BaseLayout for the shared base skeleton. Brand comes from tokens.css (which
// the seed overlays per-site); org identity comes through props from each page.
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  orgName?: string;
  primaryCta?: string;
}
const { title, description = '', orgName = 'Your Site', primaryCta = 'Get in touch' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {orgName}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <Header orgName={orgName} primaryCta={primaryCta} />
  <main><slot /></main>
  <Footer orgName={orgName} />
</body>
</html>
