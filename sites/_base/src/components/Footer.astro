---
interface Props { orgName: string; }
const { orgName } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="ft-inner">© {year} {orgName}</div>
</footer>
<style>
  .site-footer { border-top: 1px solid var(--border); background: var(--surface); margin-top: 64px; }
  .ft-inner { max-width: 1120px; margin: 0 auto; padding: 28px 24px; font-size: 13px; color: var(--ink-soft); }
</style>
